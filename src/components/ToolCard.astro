---
interface Props {
  id: string;
  name: string;
  category: string;
  categoryLabel: string;
  description: string;
  pricing: string;
  rating: number;
  link: string;
  color: string;
  icon: string;
  comingSoon?: boolean;
}

const {
  id,
  name,
  category,
  categoryLabel,
  description,
  pricing,
  rating,
  link,
  color,
  icon,
  comingSoon = false
} = Astro.props;
---

<div 
  data-category={category}
  class={`tool-card group flex flex-col justify-between bg-white border border-slate-200/60 rounded-3xl p-6 shadow-xs hover:shadow-md hover:border-slate-300 transition-all duration-300 ${comingSoon ? 'opacity-80' : ''}`}
>
  <div>
    <!-- Card Header -->
    <div class="flex items-start justify-between gap-4 mb-4">
      <!-- Custom Mock Logo Container -->
      <div class={`flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br ${color} border shadow-xs transition-transform duration-300 group-hover:scale-105`}>
        <Fragment set:html={icon} />
      </div>

      <!-- Recommend Button / Coming Soon Badge -->
      {comingSoon ? (
        <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-500/10">
          Coming Soon
        </span>
      ) : (
        <button 
          type="button" 
          class="upvote-btn flex items-center gap-1.5 rounded-xl border border-slate-200 bg-slate-50 px-3.5 py-1.5 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-600 transition-all active:scale-95 group/vote"
          data-tool-id={id}
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5 text-slate-400 group-hover/vote:text-indigo-600 group-hover/vote:scale-110 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499c.172-.468.838-.468 1.01 0l2.007 5.465a.55.55 0 0 0 .476.368l5.772.48c.52.043.727.674.33.1.006l-4.382 3.829a.55.55 0 0 0-.18.553l1.328 5.66c.12.51-.43.91-.86.63l-4.996-3.14a.55.55 0 0 0-.57 0l-4.996 3.14c-.43.28-.98-.12-.86-.63l1.328-5.66a.55.55 0 0 0-.18-.553L2.246 9.812c-.397-.332-.19-.963.33-.1.006l5.772-.48a.55.55 0 0 0 .476-.368L11.48 3.5Z" />
          </svg>
          <span class="text-xs font-semibold text-slate-700 vote-text">Recommend</span>
        </button>
      )}
    </div>

    <!-- Title & Badges -->
    <div class="flex items-center gap-2 mb-2">
      <h3 class="font-display text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
        {name}
      </h3>
      <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-0.5 text-[10px] font-semibold text-indigo-700">
        {categoryLabel}
      </span>
    </div>

    <!-- Rating Stars -->
    {!comingSoon && (
      <div class="flex items-center gap-1.5 mb-4">
        <div class="flex text-amber-400">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg class={`h-3.5 w-3.5 ${i < Math.floor(rating) ? 'fill-current' : 'text-slate-200 stroke-current'}`} viewBox="0 0 20 20" fill="currentColor">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-xs font-bold text-slate-500">{rating}</span>
      </div>
    )}

    <!-- Description -->
    <p class="text-sm text-slate-600 leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Card Footer (CTA & Pricing) -->
  <div class="mt-6 pt-4 border-t border-slate-100 flex items-center justify-between">
    <span class="text-xs font-semibold text-slate-500">
      Pricing: <span class="text-slate-900 font-bold">{pricing}</span>
    </span>
    {comingSoon ? (
      <span class="text-xs font-bold text-slate-400 italic">Planned</span>
    ) : (
      <a 
        href={link} 
        class="inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 hover:translate-x-0.5 transition-all"
      >
        Learn More
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    )}
  </div>
</div>

<script>
  const setupToolCardUpvotes = () => {
    const upvoteButtons = document.querySelectorAll('.upvote-btn');

    upvoteButtons.forEach(btn => {
      // Avoid binding event multiple times
      if (btn.getAttribute('data-upvote-listener') === 'true') return;
      btn.setAttribute('data-upvote-listener', 'true');

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const toolId = btn.getAttribute('data-tool-id');
        if (!toolId) return;

        const votedKey = `voted_${toolId}`;
        const hasVoted = localStorage.getItem(votedKey) === 'true';
        const voteTextSpan = btn.querySelector('.vote-text');

        if (hasVoted) {
          // Un-recommend
          localStorage.removeItem(votedKey);
          if (voteTextSpan) voteTextSpan.textContent = 'Recommend';
          btn.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600');
          btn.classList.add('bg-slate-50', 'text-slate-700', 'border-slate-200');
          const star = btn.querySelector('svg');
          if (star) {
            star.classList.remove('text-indigo-200', 'fill-current');
            star.classList.add('text-slate-400');
          }
        } else {
          // Recommend
          localStorage.setItem(votedKey, 'true');
          if (voteTextSpan) voteTextSpan.textContent = 'Recommended';
          btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600');
          btn.classList.remove('bg-slate-50', 'text-slate-700', 'border-slate-200');
          const star = btn.querySelector('svg');
          if (star) {
            star.classList.add('text-indigo-200', 'fill-current');
            star.classList.remove('text-slate-400');
          }
        }
      });

      // Restore states on load
      const toolId = btn.getAttribute('data-tool-id');
      if (toolId) {
        const votedKey = `voted_${toolId}`;
        const hasVoted = localStorage.getItem(votedKey) === 'true';
        if (hasVoted) {
          const voteTextSpan = btn.querySelector('.vote-text');
          if (voteTextSpan) voteTextSpan.textContent = 'Recommended';
          btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600');
          btn.classList.remove('bg-slate-50', 'text-slate-700', 'border-slate-200');
          const star = btn.querySelector('svg');
          if (star) {
            star.classList.add('text-indigo-200', 'fill-current');
            star.classList.remove('text-slate-400');
          }
        }
      }
    });
  };

  setupToolCardUpvotes();
  document.addEventListener('astro:after-swap', setupToolCardUpvotes);
</script>
