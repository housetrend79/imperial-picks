---
---

<footer class="bg-slate-50 border-t border-slate-200/80 pt-16 pb-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12 mb-12">
      
      <!-- Brand & Socials Column (Spans 2 on desktop) -->
      <div class="lg:col-span-2 space-y-6">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-violet-600 text-white shadow-md shadow-indigo-200">
            <!-- Crown SVG matching Navbar -->
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-6 w-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-display text-xl font-bold tracking-tight text-slate-900">
              Imperial<span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">Picks</span>
            </span>
            <span class="text-[9px] font-semibold tracking-widest text-indigo-600 uppercase -mt-1">AI & Software Hub</span>
          </div>
        </a>
        
        <p class="text-sm text-slate-600 leading-relaxed max-w-sm">
          Discover the top-performing artificial intelligence tools, SaaS applications, productivity resources, and interactive calculators curated daily for modern builders.
        </p>

        <!-- Social Media Links -->
        <div class="flex items-center gap-4">
          <!-- Twitter/X -->
          <a href="#" class="h-9 w-9 rounded-xl border border-slate-200 bg-white flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:border-indigo-300 transition-colors shadow-xs">
            <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- GitHub -->
          <a href="#" class="h-9 w-9 rounded-xl border border-slate-200 bg-white flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:border-indigo-300 transition-colors shadow-xs">
            <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a href="#" class="h-9 w-9 rounded-xl border border-slate-200 bg-white flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:border-indigo-300 transition-colors shadow-xs">
            <svg class="h-4.5 w-4.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links Column 1: Core Hub -->
      <div>
        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-widest mb-4">Core Directory</h4>
        <ul class="space-y-2.5">
          <li><a href="/ai-tools" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">AI Tools Hub</a></li>
          <li><a href="/software" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Software Directory</a></li>
          <li><a href="/tools" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Calculators & Tools</a></li>
          <li><a href="/blog" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Guides & Articles</a></li>
        </ul>
      </div>

      <!-- Links Column 2: Company -->
      <div>
        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-widest mb-4">Company</h4>
        <ul class="space-y-2.5">
          <li><a href="/about" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Contact Us</a></li>
          <li><a href="/sitemap" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Sitemap</a></li>
          <li><a href="/#newsletter" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Newsletter</a></li>
          <li><a href="/#submit" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Submit a Product</a></li>
        </ul>
      </div>

      <!-- Links Column 3: Legal & Compliance -->
      <div>
        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-widest mb-4">Governance</h4>
        <ul class="space-y-2.5">
          <li><a href="/privacy-policy" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Terms of Service</a></li>
          <li><a href="/disclaimer" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Disclaimer</a></li>
          <li><a href="/affiliate-disclosure" class="text-sm text-slate-600 hover:text-indigo-600 transition-colors">Affiliate Disclosure</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom border, copyright -->
    <div class="border-t border-slate-200/80 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-500 text-center sm:text-left">
        &copy; 2026 Imperial Picks. All rights reserved. Made for startup builders, marketers, and developers.
      </p>
      <div class="flex items-center gap-1">
        <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-xs font-semibold text-slate-500">All services fully operational</span>
      </div>
    </div>

  </div>
</footer>
