---
---

<section id="calculators" class="py-20 bg-white relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-800 ring-1 ring-amber-600/15 mb-4">
        Interactive Tools
      </div>
      <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Free Marketing ROI Calculator
      </h2>
      <p class="mt-4 text-base text-slate-600">
        Run mock numbers for your next marketing campaign. Tweak the budgets, conversion rates, and pricing to see estimated profit margins and return on ad spend (ROAS) instantly.
      </p>
    </div>

    <!-- Calculator Widget Container -->
    <div class="mx-auto max-w-5xl rounded-3xl border border-slate-200 bg-slate-50/50 p-6 sm:p-8 lg:p-10 shadow-lg shadow-slate-100/80">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
        
        <!-- Left Side: Inputs -->
        <div class="lg:col-span-6 space-y-6">
          <h3 class="font-display text-lg font-bold text-slate-900 border-b border-slate-200 pb-3">Campaign Metrics</h3>
          
          <!-- Input: Ad Budget -->
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label for="input-budget" class="text-sm font-semibold text-slate-700">Monthly Ad Budget ($)</label>
              <span class="text-sm font-bold text-indigo-600" id="val-budget">$5,000</span>
            </div>
            <input 
              type="range" 
              id="input-budget" 
              min="500" 
              max="50000" 
              step="500" 
              value="5000" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Input: Cost Per Click -->
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label for="input-cpc" class="text-sm font-semibold text-slate-700">Cost Per Click (CPC)</label>
              <span class="text-sm font-bold text-indigo-600" id="val-cpc">$1.00</span>
            </div>
            <input 
              type="range" 
              id="input-cpc" 
              min="0.10" 
              max="10.00" 
              step="0.05" 
              value="1.00" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Input: Conversion Rate -->
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label for="input-conv" class="text-sm font-semibold text-slate-700">Conversion Rate (%)</label>
              <span class="text-sm font-bold text-indigo-600" id="val-conv">2.5%</span>
            </div>
            <input 
              type="range" 
              id="input-conv" 
              min="0.1" 
              max="15.0" 
              step="0.1" 
              value="2.5" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Input: Sale Price (AOV) -->
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label for="input-aov" class="text-sm font-semibold text-slate-700">Average Sale Price / AOV ($)</label>
              <span class="text-sm font-bold text-indigo-600" id="val-aov">$80</span>
            </div>
            <input 
              type="range" 
              id="input-aov" 
              min="10" 
              max="1000" 
              step="5" 
              value="80" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>
        </div>

        <!-- Right Side: Outputs -->
        <div class="lg:col-span-6 flex flex-col justify-between rounded-2xl bg-white border border-slate-200/80 p-6 sm:p-8 shadow-xs">
          
          <div>
            <h3 class="font-display text-lg font-bold text-slate-900 border-b border-slate-100 pb-3">Projection Dashboard</h3>
            
            <!-- Output Cards -->
            <div class="grid grid-cols-2 gap-4 mt-6">
              
              <!-- Metric: Conversions -->
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                <span class="text-xs font-semibold text-slate-500 block">Conversions</span>
                <span class="text-2xl font-extrabold text-slate-900 mt-1 block" id="out-conversions">125</span>
              </div>
              
              <!-- Metric: Revenue -->
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                <span class="text-xs font-semibold text-slate-500 block">Est. Revenue</span>
                <span class="text-2xl font-extrabold text-slate-900 mt-1 block" id="out-revenue">$10,000</span>
              </div>

              <!-- Metric: Net Profit -->
              <div class="p-4 rounded-xl border col-span-2" id="card-profit">
                <span class="text-xs font-semibold text-slate-500 block" id="label-profit">Net Profit</span>
                <span class="text-3xl font-extrabold mt-1 block" id="out-profit">$5,000</span>
              </div>
            </div>

            <!-- Visual Graph Overlay (Ad budget vs profit) -->
            <div class="mt-6 space-y-2">
              <div class="flex items-center justify-between text-xs font-bold text-slate-500">
                <span>Visual Split (Ad Spend vs. Profit)</span>
                <span id="out-split-pct">50% / 50%</span>
              </div>
              <div class="h-4 w-full rounded-full bg-slate-100 overflow-hidden flex">
                <div class="h-full bg-indigo-500 transition-all duration-300" id="bar-spend" style="width: 50%;"></div>
                <div class="h-full bg-emerald-500 transition-all duration-300" id="bar-profit" style="width: 50%;"></div>
              </div>
            </div>
          </div>

          <!-- Bottom: ROAS status & Badge -->
          <div class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-between gap-4">
            <div>
              <span class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Estimated ROAS</span>
              <span class="text-3xl font-black text-indigo-600 mt-0.5 block" id="out-roas">2.00x</span>
            </div>
            <div class="rounded-xl px-4 py-2.5 flex items-center gap-1.5" id="out-status-badge">
              <!-- Dot Indicator -->
              <span class="h-2 w-2 rounded-full bg-white shrink-0" id="out-status-dot"></span>
              <span class="text-xs font-extrabold tracking-wide uppercase" id="out-status-text">Profitable</span>
            </div>
          </div>

        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const setupCalculator = () => {
    // Sliders
    const inputBudget = document.getElementById('input-budget') as HTMLInputElement;
    const inputCpc = document.getElementById('input-cpc') as HTMLInputElement;
    const inputConv = document.getElementById('input-conv') as HTMLInputElement;
    const inputAov = document.getElementById('input-aov') as HTMLInputElement;

    // Value Labels
    const valBudget = document.getElementById('val-budget');
    const valCpc = document.getElementById('val-cpc');
    const valConv = document.getElementById('val-conv');
    const valAov = document.getElementById('val-aov');

    // Outputs
    const outConversions = document.getElementById('out-conversions');
    const outRevenue = document.getElementById('out-revenue');
    const outProfit = document.getElementById('out-profit');
    const labelProfit = document.getElementById('label-profit');
    const cardProfit = document.getElementById('card-profit');
    const outRoas = document.getElementById('out-roas');
    const outSplitPct = document.getElementById('out-split-pct');
    const barSpend = document.getElementById('bar-spend');
    const barProfit = document.getElementById('bar-profit');

    // Badges
    const outStatusBadge = document.getElementById('out-status-badge');
    const outStatusDot = document.getElementById('out-status-dot');
    const outStatusText = document.getElementById('out-status-text');

    if (
      !inputBudget || !inputCpc || !inputConv || !inputAov ||
      !valBudget || !valCpc || !valConv || !valAov ||
      !outConversions || !outRevenue || !outProfit || !cardProfit ||
      !outRoas || !outSplitPct || !barSpend || !barProfit ||
      !outStatusBadge || !outStatusDot || !outStatusText
    ) return;

    const formatCurrency = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(val);
    };

    const calculate = () => {
      const budget = parseFloat(inputBudget.value);
      const cpc = parseFloat(inputCpc.value);
      const convRate = parseFloat(inputConv.value) / 100;
      const aov = parseFloat(inputAov.value);

      // Update Slider Value displays
      valBudget.textContent = formatCurrency(budget);
      valCpc.textContent = `$${cpc.toFixed(2)}`;
      valConv.textContent = `${(convRate * 100).toFixed(1)}%`;
      valAov.textContent = formatCurrency(aov);

      // Calculations
      const clicks = budget / cpc;
      const conversions = Math.round(clicks * convRate);
      const revenue = conversions * aov;
      const profit = revenue - budget;
      const roas = budget > 0 ? (revenue / budget) : 0;
      const roi = budget > 0 ? (profit / budget) * 100 : 0;

      // Update output metrics
      outConversions.textContent = new Intl.NumberFormat('en-US').format(conversions);
      outRevenue.textContent = formatCurrency(revenue);
      outRoas.textContent = `${roas.toFixed(2)}x`;

      // Color coding and displays for profit/loss
      if (profit >= 0) {
        // Profitable state
        outProfit.textContent = formatCurrency(profit);
        if (labelProfit) labelProfit.textContent = 'Est. Net Profit';
        
        cardProfit.className = 'p-4 rounded-xl border col-span-2 bg-emerald-50/50 border-emerald-200 text-emerald-800';
        outProfit.className = 'text-3xl font-extrabold mt-1 block text-emerald-800';

        // Badge styling
        outStatusBadge.className = 'rounded-xl px-4 py-2.5 flex items-center gap-1.5 bg-emerald-100 text-emerald-800';
        outStatusDot.className = 'h-2 w-2 rounded-full bg-emerald-500 shrink-0';
        outStatusText.textContent = `Profitable (${roi.toFixed(0)}% ROI)`;

        // Visual graph
        const total = budget + profit;
        const spendPct = (budget / total) * 100;
        const profitPct = (profit / total) * 100;
        barSpend.style.width = `${spendPct}%`;
        barProfit.style.width = `${profitPct}%`;
        barProfit.className = 'h-full bg-emerald-500 transition-all duration-300';
        outSplitPct.textContent = `${spendPct.toFixed(0)}% Spend / ${profitPct.toFixed(0)}% Profit`;
      } else {
        // Net Loss state
        const loss = Math.abs(profit);
        outProfit.textContent = `-${formatCurrency(loss)}`;
        if (labelProfit) labelProfit.textContent = 'Est. Campaign Net Loss';

        cardProfit.className = 'p-4 rounded-xl border col-span-2 bg-rose-50/50 border-rose-200 text-rose-800';
        outProfit.className = 'text-3xl font-extrabold mt-1 block text-rose-800';

        // Badge styling
        outStatusBadge.className = 'rounded-xl px-4 py-2.5 flex items-center gap-1.5 bg-rose-100 text-rose-800';
        outStatusDot.className = 'h-2 w-2 rounded-full bg-rose-500 shrink-0';
        outStatusText.textContent = `Negative Return (${roi.toFixed(0)}% ROI)`;

        // Visual graph (spent is 100%, profit is 0 since it is a loss)
        barSpend.style.width = '100%';
        barProfit.style.width = '0%';
        barProfit.className = 'h-full bg-rose-400 transition-all duration-300';
        outSplitPct.textContent = `100% Ad Spend (No Profit Margin)`;
      }
    };

    // Listeners
    [inputBudget, inputCpc, inputConv, inputAov].forEach(input => {
      input.addEventListener('input', calculate);
    });

    // Run first calculation
    calculate();
  };

  setupCalculator();
  document.addEventListener('astro:after-swap', setupCalculator);
</script>
