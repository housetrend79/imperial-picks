---
interface Props {
  id: string;
  title: string;
  description: string;
  count: string;
  tags: string[];
  gradient: string;
  shadow: string;
  bgLight: string;
  textCol: string;
  iconPath: string;
  link?: string;
}

const {
  id,
  title,
  description,
  count,
  tags,
  gradient,
  shadow,
  bgLight,
  textCol,
  link = `/${id}`
} = Astro.props;
---

<a 
  href={link}
  class="group flex flex-col justify-between p-6 bg-slate-50 border border-slate-200/60 rounded-3xl hover:bg-white hover:border-slate-300 hover:shadow-lg transition-all duration-300 hover:-translate-y-1 relative overflow-hidden"
>
  <!-- Accent top-bar gradient on hover -->
  <div class={`absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r ${gradient} transform scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300`}></div>
  
  <div>
    <!-- Icon -->
    <div class={`flex h-12 w-12 items-center justify-center rounded-2xl ${bgLight} ${textCol} mb-6 transition-transform duration-300 group-hover:scale-110`}>
      <slot name="icon" />
    </div>

    <!-- Title -->
    <h3 class="font-display text-xl font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
      {title}
    </h3>

    <!-- Description -->
    <p class="mt-2 text-sm text-slate-600 leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Bottom Footer elements -->
  <div class="mt-8 border-t border-slate-200/50 pt-4 flex flex-col gap-3">
    <span class="text-xs font-semibold text-slate-400 tracking-wide">
      {count}
    </span>
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="inline-flex items-center rounded-md bg-white px-2 py-0.5 text-[10px] font-medium text-slate-500 border border-slate-200/60">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
