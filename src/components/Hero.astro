---
---

<section class="relative overflow-hidden bg-slate-50 pt-20 pb-16 md:pt-28 md:pb-24">
  <!-- Grid backdrop and gradient glow -->
  <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none w-[500px] h-[500px] sm:w-[800px] sm:h-[800px] bg-indigo-500/5 bg-gradient-radial from-indigo-500/10 via-transparent to-transparent blur-3xl"></div>
  
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    
    <!-- Badge -->
    <div class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3.5 py-1.5 text-xs font-semibold text-indigo-700 ring-1 ring-indigo-700/10 ring-inset mb-6 sm:mb-8 animate-fade-in">
      <span class="flex h-1.5 w-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
      Your Curated AI & Business Directory
    </div>

    <!-- Title -->
    <h1 class="font-display text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl md:text-6xl max-w-4xl mx-auto leading-[1.1]">
      Discover the Best <span class="bg-gradient-to-r from-indigo-600 via-violet-600 to-indigo-500 bg-clip-text text-transparent">AI Tools</span> & Online Business Resources
    </h1>
    
    <!-- Subtitle -->
    <p class="mt-6 text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
      Imperial Picks is your ultimate guide to finding premium AI software, SaaS tools, free business calculators, and marketing resources to accelerate your growth.
    </p>

    <!-- Search Box -->
    <div class="mt-10 max-w-xl mx-auto px-2">
      <form action="#popular-tools" method="GET" class="relative flex items-center rounded-2xl bg-white p-1.5 shadow-xl shadow-slate-200/50 border border-slate-200/80 focus-within:border-indigo-500 focus-within:ring-2 focus-within:ring-indigo-150 transition-all duration-300">
        <div class="flex items-center flex-1 px-3">
          <!-- Search Icon -->
          <svg class="h-5 w-5 text-slate-400 mr-2.5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.602 10.602Z" />
          </svg>
          <input 
            type="text" 
            name="search" 
            placeholder="Search tools, calculators, templates..." 
            class="w-full bg-transparent text-slate-800 placeholder-slate-400 focus:outline-none text-sm md:text-base font-normal"
            id="hero-search-input"
          />
        </div>
        <button 
          type="submit" 
          class="rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-indigo-100 hover:bg-indigo-500 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500/25 active:scale-[0.98]"
        >
          Search
        </button>
      </form>
      
      <!-- Trending tags -->
      <div class="mt-4 flex flex-wrap items-center justify-center gap-2 text-xs text-slate-500">
        <span class="font-medium">Trending:</span>
        <button onclick="document.getElementById('hero-search-input').value = 'Claude 3.5'; document.getElementById('hero-search-input').focus();" class="hover:text-indigo-600 hover:underline">Claude 3.5</button>
        <span class="text-slate-300">•</span>
        <button onclick="document.getElementById('hero-search-input').value = 'ROI Calculator'; document.getElementById('hero-search-input').focus();" class="hover:text-indigo-600 hover:underline">ROI Calculator</button>
        <span class="text-slate-300">•</span>
        <button onclick="document.getElementById('hero-search-input').value = 'Midjourney'; document.getElementById('hero-search-input').focus();" class="hover:text-indigo-600 hover:underline">Midjourney</button>
        <span class="text-slate-300">•</span>
        <button onclick="document.getElementById('hero-search-input').value = 'Notion Template'; document.getElementById('hero-search-input').focus();" class="hover:text-indigo-600 hover:underline">Notion</button>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-16 sm:mt-20 border-t border-slate-200/80 pt-10 sm:pt-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="flex flex-col items-center p-4 bg-white/40 border border-slate-100 rounded-2xl backdrop-blur-xs">
          <span class="text-3xl font-extrabold text-indigo-600 tracking-tight font-display">Curated</span>
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">AI Tools</span>
        </div>
        <div class="flex flex-col items-center p-4 bg-white/40 border border-slate-100 rounded-2xl backdrop-blur-xs">
          <span class="text-3xl font-extrabold text-indigo-600 tracking-tight font-display">Free</span>
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Calculators</span>
        </div>
        <div class="flex flex-col items-center p-4 bg-white/40 border border-slate-100 rounded-2xl backdrop-blur-xs">
          <span class="text-3xl font-extrabold text-indigo-600 tracking-tight font-display">Verified</span>
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Resources</span>
        </div>
        <div class="flex flex-col items-center p-4 bg-white/40 border border-slate-100 rounded-2xl backdrop-blur-xs">
          <span class="text-3xl font-extrabold text-indigo-600 tracking-tight font-display">Regular</span>
          <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Updates</span>
        </div>
      </div>
    </div>

  </div>
</section>
