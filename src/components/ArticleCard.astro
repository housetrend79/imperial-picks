---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  readTime: string;
  author: string;
  authorInitials: string;
  authorColor?: string;
  visualClass: string;
  link: string;
  visualPattern: string;
  tags?: string[];
}

const {
  title,
  excerpt,
  category,
  date,
  readTime,
  author,
  authorInitials,
  authorColor = "bg-indigo-600 text-indigo-50",
  visualClass,
  link,
  visualPattern,
  tags = []
} = Astro.props;
---

<article class="group flex flex-col justify-between bg-white border border-slate-200/60 rounded-3xl overflow-hidden shadow-xs hover:shadow-md hover:border-slate-300 transition-all duration-300">
  <div>
    <!-- Visual Card Header -->
    <div class={`h-48 w-full bg-gradient-to-br ${visualClass} relative overflow-hidden flex items-center justify-center`}>
      <Fragment set:html={visualPattern} />
      
      <!-- Floating Category Badge -->
      <span class="absolute bottom-4 left-4 inline-flex items-center rounded-lg bg-black/30 backdrop-blur-md px-2.5 py-1 text-xs font-bold text-white uppercase tracking-wider">
        {category}
      </span>
    </div>

    <!-- Content Area -->
    <div class="p-6">
      <div class="flex items-center gap-2 text-xs text-slate-400 font-semibold mb-3">
        <time datetime={date}>{date}</time>
        <span>•</span>
        <span>{readTime}</span>
      </div>

      <h3 class="font-display text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors leading-snug">
        <a href={link}>
          {title}
        </a>
      </h3>

      <p class="mt-3 text-sm text-slate-600 leading-relaxed line-clamp-3">
        {excerpt}
      </p>

      {tags && tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1">
          {tags.map((tag) => (
            <span class="inline-flex items-center rounded-md bg-slate-50 px-2 py-0.5 text-[10px] font-medium text-slate-500 border border-slate-200/40">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Card Footer (Author) -->
  <div class="px-6 pb-6 pt-4 border-t border-slate-50 flex items-center gap-3">
    <div class={`h-8 w-8 rounded-full ${authorColor} flex items-center justify-center font-display text-xs font-bold shrink-0`}>
      {authorInitials}
    </div>
    <div class="text-xs">
      <p class="font-bold text-slate-800">{author}</p>
      <p class="text-slate-400 font-medium font-display">Contributor Analyst</p>
    </div>
  </div>
</article>
