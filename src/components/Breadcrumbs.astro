---
interface BreadcrumbItem {
  label: string;
  link?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="flex text-xs font-semibold text-slate-500 gap-1.5 mb-6 relative z-10" aria-label="Breadcrumb">
  {items.map((item, index) => {
    const isLast = index === items.length - 1;
    return (
      <div class="flex items-center gap-1.5">
        {index > 0 && <span class="text-slate-400 select-none">/</span>}
        {isLast ? (
          <span class="text-slate-800 font-bold truncate max-w-[200px] sm:max-w-xs md:max-w-md" aria-current="page">
            {item.label}
          </span>
        ) : (
          <a href={item.link} class="hover:text-indigo-600 transition-colors">
            {item.label}
          </a>
        )}
      </div>
    );
  })}
</nav>
