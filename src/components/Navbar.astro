---
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200/80 bg-slate-50/80 backdrop-blur-md transition-all duration-300" id="main-header">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-slate-200/80 shadow-xs overflow-hidden transition-transform duration-300 group-hover:scale-105">
          <img src="/favicon.svg" alt="ImperialPicks Logo" class="h-10 w-10" />
        </div>
        <div class="flex flex-col">
          <span class="font-display text-xl font-bold tracking-tight text-slate-900">
            Imperial<span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">Picks</span>
          </span>
          <span class="text-[9px] font-semibold tracking-widest text-indigo-600 uppercase -mt-1">AI & Software Hub</span>
        </div>
      </a>

      <!-- Desktop Nav Links -->
      <nav class="hidden md:flex items-center gap-8">
        <a href="/#categories" class="text-sm font-medium text-slate-600 transition-colors hover:text-indigo-600">Categories</a>
        <a href="/#popular-tools" class="text-sm font-medium text-slate-600 transition-colors hover:text-indigo-600">Popular Tools</a>
        <a href="/#calculators" class="text-sm font-medium text-slate-600 transition-colors hover:text-indigo-600">Free Calculators</a>
        <a href="/blog" class="text-sm font-medium text-slate-600 transition-colors hover:text-indigo-600">Articles</a>
      </nav>

      <!-- Right CTAs -->
      <div class="hidden md:flex items-center gap-4">
        <!-- Search Button -->
        <button 
          type="button" 
          id="nav-search-btn"
          class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3.5 py-2 text-xs font-semibold text-slate-500 hover:border-indigo-300 hover:text-indigo-600 transition-all shadow-xs focus:outline-none"
          aria-label="Search site"
        >
          <svg class="h-4 w-4 text-slate-400 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.602 10.602Z" />
          </svg>
          <span>Search</span>
          <kbd class="hidden lg:inline-block rounded bg-slate-100 border border-slate-200 px-1.5 py-0.5 text-[9px] font-bold text-slate-400 select-none">⌘K</kbd>
        </button>

        <a href="/#newsletter" class="text-sm font-medium text-slate-600 transition-colors hover:text-indigo-600">Subscribe</a>
        <a 
          href="/contact" 
          class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4.5 py-2 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-slate-800 hover:shadow hover:scale-[1.02] active:scale-[0.98]"
        >
          Submit a Tool
        </a>
      </div>

      <!-- Mobile Menu Button & Search -->
      <div class="flex items-center gap-2 md:hidden">
        <!-- Mobile Search Button -->
        <button 
          type="button" 
          id="mobile-search-btn"
          class="inline-flex items-center justify-center rounded-xl p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-900 focus:outline-none transition-colors"
          aria-label="Open search"
        >
          <svg class="h-5.5 w-5.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.602 10.602Z" />
          </svg>
        </button>

        <button 
          type="button" 
          id="mobile-menu-btn"
          class="inline-flex items-center justify-center rounded-xl p-2 text-slate-500 hover:bg-slate-100 hover:text-slate-900 focus:outline-none transition-colors"
          aria-controls="mobile-menu" 
          aria-expanded="false"
        >
          <span class="sr-only">Open main menu</span>
          <!-- Hamburger Icon -->
          <svg class="h-6 w-6 block" id="hamburger-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Close Icon -->
          <svg class="h-6 w-6 hidden" id="close-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div class="hidden md:hidden border-t border-slate-200 bg-slate-50/95 backdrop-blur-lg" id="mobile-menu">
    <div class="px-4 pt-3 pb-1">
      <!-- Mobile Menu Search Box -->
      <button 
        type="button" 
        id="mobile-menu-search-trigger"
        class="w-full flex items-center gap-2.5 rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 text-sm font-medium text-slate-400 focus:outline-none hover:border-indigo-300 transition-colors"
      >
        <svg class="h-4.5 w-4.5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.602 10.602Z" />
        </svg>
        <span>Search site...</span>
      </button>
    </div>
    <div class="space-y-1 px-4 py-3">
      <a href="/#categories" class="mobile-nav-link block rounded-xl px-4 py-2.5 text-base font-medium text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition-colors">Categories</a>
      <a href="/#popular-tools" class="mobile-nav-link block rounded-xl px-4 py-2.5 text-base font-medium text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition-colors">Popular Tools</a>
      <a href="/#calculators" class="mobile-nav-link block rounded-xl px-4 py-2.5 text-base font-medium text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition-colors">Free Calculators</a>
      <a href="/blog" class="mobile-nav-link block rounded-xl px-4 py-2.5 text-base font-medium text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition-colors">Articles</a>
      <a href="/#newsletter" class="mobile-nav-link block rounded-xl px-4 py-2.5 text-base font-medium text-slate-700 hover:bg-slate-100 hover:text-indigo-600 transition-colors">Subscribe</a>
      <div class="pt-4 border-t border-slate-200 mt-2 px-4">
        <a 
          href="/contact" 
          class="mobile-nav-link flex w-full items-center justify-center rounded-xl bg-indigo-600 py-3 text-center text-base font-semibold text-white shadow-md shadow-indigo-150 transition-colors hover:bg-indigo-700"
        >
          Submit a Tool
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const setupHeader = () => {
    const header = document.getElementById('main-header');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    if (!header || !mobileMenuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;

    // Scroll shadow effect
    const handleScroll = () => {
      if (window.scrollY > 10) {
        header.classList.add('shadow-sm', 'border-slate-200');
        header.classList.remove('border-slate-200/80');
      } else {
        header.classList.remove('shadow-sm', 'border-slate-200');
        header.classList.add('border-slate-200/80');
      }
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll();

    // Toggle menu function
    const toggleMenu = () => {
      const isExpanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      
      mobileMenuBtn.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      
      // Prevent body scrolling when menu is open
      if (!isExpanded) {
        document.body.classList.add('overflow-hidden');
      } else {
        document.body.classList.remove('overflow-hidden');
      }
    };

    mobileMenuBtn.addEventListener('click', toggleMenu);

    // Close menu when clicking a link
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (!mobileMenu.classList.contains('hidden')) {
          toggleMenu();
        }
      });
    });

    // Search trigger setup
    const navSearchBtn = document.getElementById('nav-search-btn');
    const mobileSearchBtn = document.getElementById('mobile-search-btn');
    const mobileMenuSearchTrigger = document.getElementById('mobile-menu-search-trigger');

    const triggerSearch = () => {
      // If mobile menu is open, close it first
      if (!mobileMenu.classList.contains('hidden')) {
        toggleMenu();
      }
      window.dispatchEvent(new CustomEvent('open-global-search'));
    };

    if (navSearchBtn) navSearchBtn.addEventListener('click', triggerSearch);
    if (mobileSearchBtn) mobileSearchBtn.addEventListener('click', triggerSearch);
    if (mobileMenuSearchTrigger) mobileMenuSearchTrigger.addEventListener('click', triggerSearch);
  };

  // Run on page load
  setupHeader();

  // Support Astro view transitions / re-runs if added in the future
  document.addEventListener('astro:after-swap', setupHeader);
</script>
