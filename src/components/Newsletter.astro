---
---

<section id="newsletter" class="py-16 bg-white relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Newsletter Container -->
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-950 px-6 py-12 sm:px-12 sm:py-16 lg:px-16 lg:py-20 text-center shadow-xl shadow-indigo-950/20">
      
      <!-- Grid Overlay -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none"></div>
      <!-- Radial Spotlight Glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none w-[400px] h-[400px] bg-indigo-500/10 rounded-full blur-3xl"></div>

      <div class="relative max-w-2xl mx-auto flex flex-col items-center">
        <!-- Icon -->
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>

        <h2 class="font-display text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Get the Best Tools in Your Inbox
        </h2>
        <p class="mt-4 text-base text-slate-300">
          Subscribe to receive a weekly digest containing curated AI tools, business calculators, and software resources.
        </p>

        <!-- Subscription Form -->
        <form 
          id="newsletter-form" 
          class="mt-8 flex w-full max-w-md flex-col sm:flex-row gap-3 transition-all duration-300"
        >
          <div class="relative flex-1">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="h-5 w-5 text-slate-400" viewBox="0 0 20 20" fill="currentColor">
                <path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.22a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z" />
                <path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z" />
              </svg>
            </div>
            <input 
              id="newsletter-email" 
              type="email" 
              required 
              placeholder="Enter your email address" 
              class="w-full rounded-2xl bg-white/5 border border-white/10 py-3 pl-11 pr-4 text-sm text-white placeholder-slate-400 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/25 transition-all"
            />
          </div>
          <button 
            type="submit" 
            class="rounded-2xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-indigo-600/10 hover:bg-indigo-500 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 active:scale-[0.98]"
          >
            Subscribe Now
          </button>
        </form>

        <!-- Interactive Success State (Initially Hidden) -->
        <div 
          id="newsletter-success" 
          class="hidden mt-8 p-6 rounded-2xl bg-indigo-950/50 border border-indigo-500/30 text-center animate-fade-in max-w-md w-full"
        >
          <span class="text-3xl block mb-2">🎉</span>
          <h3 class="text-lg font-bold text-white font-display">You're Subscribed!</h3>
          <p class="mt-2 text-sm text-indigo-200">
            Thank you for joining Imperial Picks. Please check your inbox to confirm your subscription.
          </p>
        </div>

      </div>

    </div>

  </div>
</section>

<script>
  const setupNewsletter = () => {
    const form = document.getElementById('newsletter-form');
    const successDiv = document.getElementById('newsletter-success');

    if (!form || !successDiv) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Perform mock API subscription call
      form.classList.add('opacity-0', 'scale-95');
      setTimeout(() => {
        form.classList.add('hidden');
        successDiv.classList.remove('hidden');
        successDiv.classList.add('block');
      }, 300);
    });
  };

  setupNewsletter();
  document.addEventListener('astro:after-swap', setupNewsletter);
</script>
