---

<section id="popular-tools" class="py-20 bg-slate-50 relative border-t border-b border-slate-200/60">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header + Controls -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
      <div class="max-w-2xl">
        <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Popular Picks & Tools
        </h2>
        <p class="mt-3 text-base text-slate-600">
          Discover the top-voted solutions as rated by developers, marketers, and startup builders globally.
        </p>
      </div>

      <!-- Category Filter Tabs -->
      <div class="flex flex-wrap gap-2 rounded-2xl bg-white p-1 border border-slate-200/60 shadow-xs self-start md:self-auto">
        <button 
          data-filter="all" 
          class="tool-filter-btn rounded-xl px-4 py-2 text-sm font-semibold text-indigo-600 bg-indigo-50 transition-all duration-200"
        >
          All Picks
        </button>
        <button 
          data-filter="ai-tools" 
          class="tool-filter-btn rounded-xl px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all duration-200"
        >
          AI Tools
        </button>
        <button 
          data-filter="software" 
          class="tool-filter-btn rounded-xl px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all duration-200"
        >
          Software
        </button>
        <button 
          data-filter="calculators" 
          class="tool-filter-btn rounded-xl px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 transition-all duration-200"
        >
          Calculators
        </button>
      </div>
    </div>

    <!-- Tools Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="tools-grid">
      {tools.map((tool) => (
        <div 
          data-category={tool.category}
          class="tool-card group flex flex-col justify-between bg-white border border-slate-200/60 rounded-3xl p-6 shadow-xs hover:shadow-md hover:border-slate-300 transition-all duration-300"
        >
          <div>
            <!-- Card Header (Logo, badges, rating, upvote) -->
            <div class="flex items-start justify-between gap-4 mb-4">
              <!-- Custom Mock Logo Container -->
              <div class={`flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br ${tool.color} border shadow-xs transition-transform duration-300 group-hover:scale-105`}>
                <Fragment set:html={tool.icon} />
              </div>

              <!-- Vote Button -->
              <button 
                type="button" 
                class="upvote-btn flex flex-col items-center justify-center rounded-xl border border-slate-200 bg-slate-50 px-3 py-1.5 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-600 transition-all active:scale-95 group/vote"
                data-tool-id={tool.id}
                data-votes={tool.votes}
              >
                <!-- Chevron Up -->
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 text-slate-400 group-hover/vote:text-indigo-600 group-hover/vote:-translate-y-0.5 transition-transform">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
                </svg>
                <span class="text-xs font-bold text-slate-700 mt-0.5 vote-count">{tool.votes}</span>
              </button>
            </div>

            <!-- Title & Badges -->
            <div class="flex items-center gap-2 mb-2">
              <h3 class="font-display text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">
                {tool.name}
              </h3>
              <!-- Category Badge -->
              <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-0.5 text-[10px] font-semibold text-indigo-700">
                {tool.categoryLabel}
              </span>
            </div>

            <!-- Rating Stars -->
            <div class="flex items-center gap-1.5 mb-4">
              <div class="flex text-amber-400">
                <!-- Stars SVGs -->
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`h-3.5 w-3.5 ${i < Math.floor(tool.rating) ? 'fill-current' : 'text-slate-200 stroke-current'}`} viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <span class="text-xs font-bold text-slate-500">{tool.rating}</span>
            </div>

            <!-- Description -->
            <p class="text-sm text-slate-600 leading-relaxed">
              {tool.description}
            </p>
          </div>

          <!-- Card Footer (CTA & Pricing) -->
          <div class="mt-6 pt-4 border-t border-slate-100 flex items-center justify-between">
            <span class="text-xs font-semibold text-slate-500">
              Pricing: <span class="text-slate-900 font-bold">{tool.pricing}</span>
            </span>
            <a 
              href={tool.link} 
              class="inline-flex items-center gap-1 text-xs font-bold text-indigo-600 hover:text-indigo-500 hover:translate-x-0.5 transition-all"
            >
              Learn More
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const setupTools = () => {
    // 1. Category Filter Logic
    const filterButtons = document.querySelectorAll('.tool-filter-btn');
    const toolCards = document.querySelectorAll('.tool-card');

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filterValue = btn.getAttribute('data-filter');

        // Toggle active states
        filterButtons.forEach(b => {
          b.classList.remove('bg-indigo-50', 'text-indigo-600');
          b.classList.add('text-slate-600', 'hover:text-slate-900');
        });
        btn.classList.add('bg-indigo-50', 'text-indigo-600');
        btn.classList.remove('text-slate-600', 'hover:text-slate-900');

        // Toggle cards
        toolCards.forEach(card => {
          const cardCat = card.getAttribute('data-category');
          if (filterValue === 'all' || cardCat === filterValue) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });

    // 2. Upvote Interactive Logic
    const upvoteButtons = document.querySelectorAll('.upvote-btn');

    upvoteButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const toolId = btn.getAttribute('data-tool-id');
        if (!toolId) return;

        const votedKey = `voted_${toolId}`;
        const hasVoted = localStorage.getItem(votedKey) === 'true';
        const voteCountSpan = btn.querySelector('.vote-count');
        const initialVotes = parseInt(btn.getAttribute('data-votes') || '0', 10);

        if (hasVoted) {
          // Decrement vote
          localStorage.removeItem(votedKey);
          if (voteCountSpan) voteCountSpan.textContent = String(initialVotes);
          btn.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600', 'hover:bg-indigo-700');
          btn.classList.add('bg-slate-50', 'text-slate-700', 'border-slate-200');
          const chevron = btn.querySelector('svg');
          if (chevron) {
            chevron.classList.remove('text-indigo-200');
            chevron.classList.add('text-slate-400');
          }
        } else {
          // Increment vote
          localStorage.setItem(votedKey, 'true');
          if (voteCountSpan) voteCountSpan.textContent = String(initialVotes + 1);
          btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600', 'hover:bg-indigo-700');
          btn.classList.remove('bg-slate-50', 'text-slate-700', 'border-slate-200');
          const chevron = btn.querySelector('svg');
          if (chevron) {
            chevron.classList.add('text-indigo-200');
            chevron.classList.remove('text-slate-400');
          }
        }
      });

      // Restore states on load
      const toolId = btn.getAttribute('data-tool-id');
      if (toolId) {
        const votedKey = `voted_${toolId}`;
        const hasVoted = localStorage.getItem(votedKey) === 'true';
        if (hasVoted) {
          const voteCountSpan = btn.querySelector('.vote-count');
          const initialVotes = parseInt(btn.getAttribute('data-votes') || '0', 10);
          if (voteCountSpan) voteCountSpan.textContent = String(initialVotes + 1);
          btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600');
          btn.classList.remove('bg-slate-50', 'text-slate-700', 'border-slate-200');
          const chevron = btn.querySelector('svg');
          if (chevron) {
            chevron.classList.add('text-indigo-200');
            chevron.classList.remove('text-slate-400');
          }
        }
      }
    });
  };

  setupTools();
  document.addEventListener('astro:after-swap', setupTools);
</script>
