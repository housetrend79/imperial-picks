---
import { articles as allArticles } from "../data/articles.js";

// Fetch the 3 most recent articles
const articles = allArticles.slice(0, 3);
---

<section id="articles" class="py-20 bg-slate-50 relative border-t border-slate-200/60">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-800 ring-1 ring-indigo-600/15 mb-4">
        Guides & Analytics
      </div>
      <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Latest Editorial Picks & Guides
      </h2>
      <p class="mt-4 text-base text-slate-600">
        Stay ahead with deep dives into product launches, digital marketing formulas, and modern software architectures.
      </p>
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {articles.map((art) => (
        <article class="group flex flex-col justify-between bg-white border border-slate-200/60 rounded-3xl overflow-hidden shadow-xs hover:shadow-md hover:border-slate-300 transition-all duration-300">
          
          <div>
            <!-- Visual Card Header (Replaces default images) -->
            <div class={`h-48 w-full bg-gradient-to-br ${art.visualClass} relative overflow-hidden flex items-center justify-center`}>
              <Fragment set:html={art.visualPattern} />
              
              <!-- Floating Title Icon Badge -->
              <span class="absolute bottom-4 left-4 inline-flex items-center rounded-lg bg-black/30 backdrop-blur-md px-2.5 py-1 text-xs font-bold text-white uppercase tracking-wider">
                {art.category}
              </span>
            </div>

            <!-- Content Area -->
            <div class="p-6">
              <div class="flex items-center gap-2 text-xs text-slate-400 font-semibold mb-3">
                <time datetime="2026-06-08">{art.date}</time>
                <span>•</span>
                <span>{art.readTime}</span>
              </div>

              <h3 class="font-display text-lg font-bold text-slate-900 group-hover:text-indigo-600 transition-colors leading-snug">
                <a href={art.link}>
                  {art.title}
                </a>
              </h3>

              <p class="mt-3 text-sm text-slate-600 leading-relaxed line-clamp-3">
                {art.excerpt}
              </p>
            </div>
          </div>

          <!-- Card Footer (Author) -->
          <div class="px-6 pb-6 pt-4 border-t border-slate-50 flex items-center gap-3">
            <div class={`h-8 w-8 rounded-full ${art.authorColor} flex items-center justify-center font-display text-xs font-bold shrink-0`}>
              {art.authorInitials}
            </div>
            <div class="text-xs">
              <p class="font-bold text-slate-800">{art.author}</p>
              <p class="text-slate-400 font-medium">Contributor Analyst</p>
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>
