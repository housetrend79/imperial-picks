---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { articles } from "../data/articles.js";
import { calculators } from "../data/calculators.js";

const breadcrumbItems = [
  { label: "Home", link: "/" },
  { label: "Sitemap" }
];
---

<Layout title="Sitemap - Imperial Picks" description="Navigate through all the articles, calculators, software hubs, and legal policies on Imperial Picks.">
  <Navbar />
  
  <main class="relative bg-slate-50 min-h-screen py-12">
    <!-- Background Patterns -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>

    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbItems} />

      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-12">
        <span class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-bold text-indigo-850 ring-1 ring-indigo-650/15 mb-4">
          Directory
        </span>
        <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Imperial Picks Sitemap
        </h1>
        <p class="mt-3 text-base text-slate-600">
          Find and navigate directly to any of our interactive calculators, editorial reviews, topic hubs, or corporate policy pages.
        </p>
      </div>

      <!-- Sitemap Content -->
      <div class="space-y-10 bg-white border border-slate-200 rounded-3xl p-6 sm:p-10 shadow-xs">
        
        <!-- Category: Topic Hubs -->
        <div>
          <h2 class="font-display text-lg font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4 flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-indigo-600"></span> Core Directories
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-1 text-sm">
            <li>
              <a href="/" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Home Page →
              </a>
            </li>
            <li>
              <a href="/ai-tools" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                AI Tools Hub →
              </a>
            </li>
            <li>
              <a href="/tools" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Calculators & Utilities Hub →
              </a>
            </li>
            <li>
              <a href="/software" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Software Directory →
              </a>
            </li>
            <li>
              <a href="/blog" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Blog Catalog →
              </a>
            </li>
          </ul>
        </div>

        <!-- Category: Calculators -->
        <div>
          <h2 class="font-display text-lg font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4 flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-amber-500"></span> Interactive Calculators
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-1 text-sm">
            {calculators.map(calc => (
              <li>
                <a href={calc.link} class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                  {calc.name} →
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Category: AI Articles -->
        <div>
          <h2 class="font-display text-lg font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4 flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-emerald-500"></span> Editorial Guides & Reviews
          </h2>
          <ul class="space-y-3 pl-1 text-sm">
            {articles.map(art => (
              <li>
                <a href={art.link} class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline block">
                  {art.title}
                </a>
                <p class="text-xs text-slate-400 mt-0.5">{art.excerpt}</p>
              </li>
            ))}
          </ul>
        </div>

        <!-- Category: General & Corporate -->
        <div>
          <h2 class="font-display text-lg font-bold text-slate-950 border-b border-slate-100 pb-3 mb-4 flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-slate-400"></span> Corporate & Information
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-1 text-sm">
            <li>
              <a href="/about" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                About Imperial Picks →
              </a>
            </li>
            <li>
              <a href="/contact" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Contact Editorial →
              </a>
            </li>
            <li>
              <a href="/privacy-policy" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Privacy Policy →
              </a>
            </li>
            <li>
              <a href="/terms" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Terms of Service →
              </a>
            </li>
            <li>
              <a href="/disclaimer" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Legal Disclaimer →
              </a>
            </li>
            <li>
              <a href="/affiliate-disclosure" class="text-slate-600 hover:text-indigo-600 font-semibold hover:underline">
                Affiliate Disclosure →
              </a>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </main>

  <Footer />
</Layout>
