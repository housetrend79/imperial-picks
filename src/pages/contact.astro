---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact Us - Imperial Picks" description="Have questions, partnership inquiries, or products you want reviewed? Reach out to the team at Imperial Picks. We value your feedback.">
  <Navbar />
  
  <main class="relative bg-slate-50 min-h-screen">
    <!-- Background Patterns -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 pointer-events-none w-[600px] h-[600px] bg-indigo-500/5 bg-gradient-radial from-indigo-500/10 via-transparent to-transparent blur-3xl"></div>

    <!-- Header Hero -->
    <section class="relative pt-20 pb-12 sm:pt-24 text-center">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3.5 py-1.5 text-xs font-semibold text-indigo-700 ring-1 ring-indigo-700/10 ring-inset mb-6">
          Get in Touch
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 leading-[1.1]">
          We’d Love to <span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">Hear From You</span>
        </h1>
        <p class="mt-6 text-lg text-slate-600 max-w-2xl mx-auto leading-relaxed">
          For sponsorship opportunities, tool submissions, feature requests, or general inquiries, fill out the form or reach out to our support channel.
        </p>
      </div>
    </section>

    <!-- Content Section -->
    <section class="relative pb-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
          
          <!-- Contact Form UI (Left Column) -->
          <div class="lg:col-span-7 bg-white rounded-3xl border border-slate-200 p-6 sm:p-8 lg:p-10 shadow-lg shadow-slate-100/50 relative overflow-hidden">
            <h2 class="font-display text-xl font-bold text-slate-900 mb-2">Send Us a Message</h2>
            <p class="text-sm text-slate-500 mb-8">Our editorial team typically responds within 24 to 48 business hours.</p>

            <form id="contact-form" class="space-y-6 transition-all duration-300">
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <!-- Name -->
                <div class="space-y-2">
                  <label for="contact-name" class="text-xs font-bold text-slate-700 uppercase tracking-wider">Full Name</label>
                  <input 
                    type="text" 
                    id="contact-name" 
                    required 
                    placeholder="John Doe" 
                    class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all"
                  />
                </div>

                <!-- Email -->
                <div class="space-y-2">
                  <label for="contact-email" class="text-xs font-bold text-slate-700 uppercase tracking-wider">Email Address</label>
                  <input 
                    type="email" 
                    id="contact-email" 
                    required 
                    placeholder="john@example.com" 
                    class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all"
                  />
                </div>
              </div>

              <!-- Subject -->
              <div class="space-y-2">
                <label for="contact-subject" class="text-xs font-bold text-slate-700 uppercase tracking-wider">Subject</label>
                <input 
                  type="text" 
                  id="contact-subject" 
                  required 
                  placeholder="Sponsorship inquiry, tool feedback, etc." 
                  class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all"
                />
              </div>

              <!-- Message -->
              <div class="space-y-2">
                <label for="contact-message" class="text-xs font-bold text-slate-700 uppercase tracking-wider">Message</label>
                <textarea 
                  id="contact-message" 
                  required 
                  rows="5" 
                  placeholder="Tell us details about your project or inquiry..." 
                  class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-800 focus:bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition-all resize-none"
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full sm:w-auto rounded-xl bg-indigo-600 px-6 py-3.5 text-sm font-semibold text-white shadow-md shadow-indigo-150 hover:bg-indigo-500 transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 active:scale-[0.98]"
              >
                Send Message
              </button>

            </form>

            <!-- Success State -->
            <div id="contact-success" class="hidden p-8 text-center bg-indigo-50 border border-indigo-200 rounded-2xl animate-fade-in">
              <span class="text-4xl block mb-2">✉️</span>
              <h3 class="text-lg font-bold text-indigo-950 font-display">Message Dispatched!</h3>
              <p class="mt-2 text-sm text-indigo-800 max-w-sm mx-auto">
                Thank you for contacting Imperial Picks. We have logged your request and will follow up with you at the provided email shortly.
              </p>
            </div>

          </div>

          <!-- FAQ & Support Panel (Right Column) -->
          <div class="lg:col-span-5 space-y-8">
            
            <!-- Support Card -->
            <div class="p-6 rounded-3xl bg-slate-900 border border-slate-800 text-white shadow-md relative overflow-hidden">
              <div class="absolute inset-0 bg-grid-pattern opacity-5 pointer-events-none"></div>
              <h3 class="font-display text-lg font-bold">Direct Channels</h3>
              <p class="mt-2 text-xs text-slate-400">Prefer direct communications? Drop us an email or use our secure portal.</p>
              
              <div class="mt-6 flex items-center gap-3">
                <div class="h-10 w-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-indigo-400 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Inquiries Desk</span>
                  <a href="mailto:imperialpicks00@gmail.com" class="text-sm font-semibold hover:text-indigo-400 transition-colors">
                    imperialpicks00@gmail.com
                  </a>
                </div>
              </div>
            </div>

            <!-- FAQs -->
            <div class="space-y-4">
              <h3 class="font-display text-lg font-bold text-slate-900 border-b border-slate-200 pb-3">Frequently Asked Questions</h3>
              
              <div class="space-y-3">
                <!-- FAQ 1 -->
                <details class="group rounded-2xl bg-white border border-slate-200/80 p-4 transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
                  <summary class="flex items-center justify-between cursor-pointer focus:outline-none">
                    <h4 class="text-sm font-semibold text-slate-800 transition-colors group-hover:text-indigo-600">
                      How can I submit my product to Imperial Picks?
                    </h4>
                    <span class="ml-1.5 shrink-0 rounded-lg bg-slate-50 p-1 text-slate-400 group-open:rotate-180 transition-transform duration-300">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </span>
                  </summary>
                  <p class="mt-3 text-xs text-slate-500 leading-relaxed border-t border-slate-100 pt-2.5">
                    Submit your tool using the message form. Choose the subject line "Tool Submission". Make sure to include the tool URL, launch pricing tiers, and its core value proposition.
                  </p>
                </details>

                <!-- FAQ 2 -->
                <details class="group rounded-2xl bg-white border border-slate-200/80 p-4 transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
                  <summary class="flex items-center justify-between cursor-pointer focus:outline-none">
                    <h4 class="text-sm font-semibold text-slate-800 transition-colors group-hover:text-indigo-600">
                      Are your calculator projections legally binding?
                    </h4>
                    <span class="ml-1.5 shrink-0 rounded-lg bg-slate-50 p-1 text-slate-400 group-open:rotate-180 transition-transform duration-300">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </span>
                  </summary>
                  <p class="mt-3 text-xs text-slate-500 leading-relaxed border-t border-slate-100 pt-2.5">
                    No. All calculators (like our Ad Spend ROI Calculator) provide estimated projections based on static mathematical inputs. They are for planning purposes and do not represent financial guarantees.
                  </p>
                </details>

                <!-- FAQ 3 -->
                <details class="group rounded-2xl bg-white border border-slate-200/80 p-4 transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
                  <summary class="flex items-center justify-between cursor-pointer focus:outline-none">
                    <h4 class="text-sm font-semibold text-slate-800 transition-colors group-hover:text-indigo-600">
                      How does the upvoting mechanism work?
                    </h4>
                    <span class="ml-1.5 shrink-0 rounded-lg bg-slate-50 p-1 text-slate-400 group-open:rotate-180 transition-transform duration-300">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </span>
                  </summary>
                  <p class="mt-3 text-xs text-slate-500 leading-relaxed border-t border-slate-100 pt-2.5">
                    Upvoting is handled directly via browser client cookies and local storage. Registered visitors can click the upvote button once per tool. This protects rankings from automation and spam bots.
                  </p>
                </details>

                <!-- FAQ 4 -->
                <details class="group rounded-2xl bg-white border border-slate-200/80 p-4 transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
                  <summary class="flex items-center justify-between cursor-pointer focus:outline-none">
                    <h4 class="text-sm font-semibold text-slate-800 transition-colors group-hover:text-indigo-600">
                      Does Imperial Picks offer advertisement slots?
                    </h4>
                    <span class="ml-1.5 shrink-0 rounded-lg bg-slate-50 p-1 text-slate-400 group-open:rotate-180 transition-transform duration-300">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </span>
                  </summary>
                  <p class="mt-3 text-xs text-slate-500 leading-relaxed border-t border-slate-100 pt-2.5">
                    Yes. We sponsor relevant products and newsletter banners. Please fill out our contact form specifying "Sponsorship Opportunity" in the subject line.
                  </p>
                </details>
              </div>

            </div>

          </div>

        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<script>
  const setupContactForm = () => {
    const form = document.getElementById('contact-form');
    const successDiv = document.getElementById('contact-success');

    if (!form || !successDiv) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Perform mock API submit call
      form.classList.add('opacity-0', 'scale-95');
      setTimeout(() => {
        form.classList.add('hidden');
        successDiv.classList.remove('hidden');
        successDiv.classList.add('block');
      }, 300);
    });
  };

  setupContactForm();
  document.addEventListener('astro:after-swap', setupContactForm);
</script>
