---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedArticles from "../../components/RelatedArticles.astro";
---

<Layout title="Free Affiliate Earnings Calculator - Imperial Picks" description="Estimate your monthly and yearly affiliate commissions. Adjust monthly visitors, CTR, conversion rates, and commissions per sale to project earnings instantly.">
  <Navbar />
  
  <main class="relative bg-slate-50 min-h-screen py-12">
    <!-- Background Patterns -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <Breadcrumbs items={[
        { label: "Home", link: "/" },
        { label: "Calculators", link: "/tools" },
        { label: "Affiliate Earnings Calculator" }
      ]} />

      <!-- Page Header -->
      <div class="text-center max-w-3xl mx-auto mb-12 relative z-10">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-xs font-bold text-amber-800 ring-1 ring-amber-600/15 mb-4">
          Revenue Modeler
        </div>
        <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Affiliate Earnings Calculator
        </h1>
        <p class="mt-3 text-base text-slate-600">
          Model and project your affiliate marketing revenues. Adjust traffic, click-through rates, conversion rates, and payouts to see monthly and annual commission estimations.
        </p>
      </div>

      <!-- Main Widget Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 relative z-10 max-w-5xl mx-auto">
        
        <!-- Left Side: Inputs & Sliders -->
        <div class="lg:col-span-7 bg-white rounded-3xl border border-slate-200 p-6 sm:p-8 shadow-sm space-y-6">
          <h2 class="font-display text-lg font-bold text-slate-900 border-b border-slate-100 pb-3">
            Traffic & Conversion Metrics
          </h2>

          <!-- Parameter 1: Monthly Traffic -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-traffic" class="text-sm font-semibold text-slate-700">Monthly Visitors (Traffic)</label>
              <div class="flex items-center gap-2">
                <input 
                  type="number" 
                  id="num-traffic" 
                  min="1" 
                  max="10000000" 
                  value="50000"
                  class="w-24 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-right text-sm font-bold text-indigo-600 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                />
              </div>
            </div>
            <input 
              type="range" 
              id="slide-traffic" 
              min="100" 
              max="500000" 
              step="100" 
              value="50000" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Parameter 2: Click-Through Rate -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-ctr" class="text-sm font-semibold text-slate-700">Click-Through Rate (CTR %)</label>
              <div class="flex items-center gap-2">
                <input 
                  type="number" 
                  id="num-ctr" 
                  min="0.01" 
                  max="100" 
                  step="0.01"
                  value="2.00"
                  class="w-20 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-right text-sm font-bold text-indigo-600 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                />
                <span class="text-xs text-slate-400 font-bold">%</span>
              </div>
            </div>
            <input 
              type="range" 
              id="slide-ctr" 
              min="0.1" 
              max="20" 
              step="0.1" 
              value="2" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Parameter 3: Conversion Rate -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-conv" class="text-sm font-semibold text-slate-700">Sales Conversion Rate (%)</label>
              <div class="flex items-center gap-2">
                <input 
                  type="number" 
                  id="num-conv" 
                  min="0.01" 
                  max="100" 
                  step="0.01"
                  value="1.50"
                  class="w-20 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-right text-sm font-bold text-indigo-600 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                />
                <span class="text-xs text-slate-400 font-bold">%</span>
              </div>
            </div>
            <input 
              type="range" 
              id="slide-conv" 
              min="0.1" 
              max="15" 
              step="0.1" 
              value="1.5" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Parameter 4: Commission Per Sale -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-commission" class="text-sm font-semibold text-slate-700">Commission Per Sale ($)</label>
              <div class="flex items-center gap-2">
                <span class="text-xs text-slate-400 font-bold">$</span>
                <input 
                  type="number" 
                  id="num-commission" 
                  min="0.1" 
                  max="100000" 
                  step="0.5"
                  value="50.00"
                  class="w-20 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-right text-sm font-bold text-indigo-600 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                />
              </div>
            </div>
            <input 
              type="range" 
              id="slide-commission" 
              min="1" 
              max="500" 
              step="1" 
              value="50" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

        </div>

        <!-- Right Side: Projections Dashboard -->
        <div class="lg:col-span-5 flex flex-col justify-between rounded-3xl bg-slate-900 text-white border border-slate-800 p-6 sm:p-8 shadow-lg">
          
          <div>
            <h2 class="font-display text-lg font-bold border-b border-white/10 pb-3 mb-6">
              Earnings Dashboard
            </h2>

            <!-- Metric Cards -->
            <div class="space-y-4">
              <!-- Monthly Earnings -->
              <div class="p-4 rounded-2xl bg-white/5 border border-white/10">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Est. Monthly Earnings</span>
                <span class="text-3xl font-black text-indigo-400 mt-1 block" id="out-monthly">$750</span>
              </div>

              <!-- Yearly Earnings -->
              <div class="p-4 rounded-2xl bg-white/5 border border-white/10">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Est. Yearly Earnings</span>
                <span class="text-3xl font-black text-indigo-400 mt-1 block" id="out-yearly">$9,000</span>
              </div>

              <!-- Conversion statistics -->
              <div class="grid grid-cols-2 gap-4">
                <div class="p-4 rounded-xl bg-white/5 border border-white/5">
                  <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block">Monthly Clicks</span>
                  <span class="text-lg font-extrabold text-white mt-1 block" id="out-clicks">1,000</span>
                </div>
                <div class="p-4 rounded-xl bg-white/5 border border-white/5">
                  <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest block">Monthly Sales</span>
                  <span class="text-lg font-extrabold text-white mt-1 block" id="out-sales">15</span>
                </div>
              </div>
            </div>

            <!-- Visual Funnel representation -->
            <div class="mt-8 space-y-3">
              <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Conversion Funnel Scale</h3>
              
              <div class="space-y-2 text-xs">
                <!-- Traffic Layer -->
                <div class="space-y-1">
                  <div class="flex justify-between text-[10px] text-slate-400">
                    <span>Traffic</span>
                    <span id="funnel-traffic">50,000 visitors</span>
                  </div>
                  <div class="h-2 w-full rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full bg-indigo-500 w-full"></div>
                  </div>
                </div>

                <!-- Clicks Layer -->
                <div class="space-y-1">
                  <div class="flex justify-between text-[10px] text-slate-400">
                    <span>Clicks (CTR)</span>
                    <span id="funnel-clicks">1,000 clicks</span>
                  </div>
                  <div class="h-2 w-full rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full bg-indigo-400 transition-all duration-300" id="bar-clicks" style="width: 25%;"></div>
                  </div>
                </div>

                <!-- Sales Layer -->
                <div class="space-y-1">
                  <div class="flex justify-between text-[10px] text-slate-400">
                    <span>Sales (Conversions)</span>
                    <span id="funnel-sales">15 sales</span>
                  </div>
                  <div class="h-2 w-full rounded-full bg-white/10 overflow-hidden">
                    <div class="h-full bg-emerald-500 transition-all duration-300" id="bar-sales" style="width: 10%;"></div>
                  </div>
                </div>
              </div>
            </div>

          </div>

          <div class="mt-8 pt-6 border-t border-white/10 text-[10px] text-slate-400 text-center">
            Projections are estimations for planning. Real revenue depends on traffic quality and merchant rules.
          </div>

        </div>

      </div>

      <!-- Educational Content Section -->
      <section class="max-w-4xl mx-auto mt-20 bg-white border border-slate-200 rounded-3xl p-6 sm:p-10 shadow-xs">
        <h2 class="font-display text-2xl font-bold text-slate-900 mb-6 border-b border-slate-100 pb-3">
          Understanding Affiliate Commission Projections
        </h2>
        
        <div class="space-y-6 text-sm text-slate-600 leading-relaxed">
          <div>
            <h3 class="font-display text-base font-bold text-slate-900 mb-2">The Affiliate Earnings Formula</h3>
            <p>
              Your monthly affiliate commissions are calculated using a simple linear equation:
            </p>
            <div class="my-4 p-4 rounded-xl bg-slate-50 border border-slate-200/60 font-mono text-center text-xs text-indigo-700">
              Earnings = Monthly Visitors × (Click-Through Rate / 100) × (Conversion Rate / 100) × Commission Per Sale
            </div>
            <p>
              By tweaking individual parameters, you can see that even minor adjustments in your click-through rates (CTR) or conversions yield compounding changes in overall revenues.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
            
            <div class="space-y-2">
              <h4 class="font-bold text-slate-900 text-sm">How to Boost Your Click-Through Rate (CTR)</h4>
              <p class="text-xs">
                To get more visitors to click your referral links, focus on placement and context. Standard banner ads generally have lower click rates. Instead, integrate links organically within informative product comparisons, tutorials, and text guides.
              </p>
            </div>

            <div class="space-y-2">
              <h4 class="font-bold text-slate-900 text-sm">How to Improve Sales Conversions</h4>
              <p class="text-xs">
                Conversion rate depends heavily on the match between your audience and the tool. Recommending enterprise CRM software to student developers yields lower sales. Ensure the products you review match the budgets and needs of your specific visitors.
              </p>
            </div>

          </div>

          <div class="border-t border-slate-100 pt-6">
            <h3 class="font-display text-base font-bold text-slate-900 mb-2">Explore Related Tools & Guides</h3>
            <p class="text-xs leading-relaxed text-slate-500">
              If you run paid marketing campaigns, use our <a href="/tools/roi-calculator" class="text-indigo-600 font-semibold hover:underline">ROI Calculator</a> to calculate return on ad spend. Video content creators can model prospective channel ad payouts using the <a href="/tools/youtube-earnings-calculator" class="text-indigo-600 font-semibold hover:underline">YouTube Earnings Calculator</a>. Additionally, if you use AI to generate review copy or portfolios, explore our independent audits of the <a href="/ai-tools/best-ai-writing-tools" class="text-indigo-600 font-semibold hover:underline">Best AI Writing Tools</a> and the <a href="/ai-tools/best-ai-resume-builders" class="text-indigo-600 font-semibold hover:underline">Best AI Resume Builders</a>.
            </p>
          </div>

          <div class="border-t border-slate-100 pt-6">
            <h3 class="font-display text-base font-bold text-slate-900 mb-2">Our Curation Policy</h3>
            <p class="text-xs">
              At Imperial Picks, we maintain transparency regarding affiliate links. While we participate in referral programs to support our calculators and guides, these partnerships never compromise our editorial reviews. We evaluate tools objectively based on features, speed, and overall value. Read our full <a href="/affiliate-disclosure" class="text-indigo-600 font-semibold hover:underline">Affiliate Disclosure</a> for details.
            </p>
          </div>
        </div>
      </section>

    
      <!-- Related Articles Section -->
      <RelatedArticles currentPath="/tools/affiliate-earnings-calculator" currentCategory="Tools" />
</div>
  </main>

  <Footer />
</Layout>

<script>
  const setupAffiliateCalculator = () => {
    // Sliders
    const slideTraffic = document.getElementById('slide-traffic') as HTMLInputElement;
    const slideCtr = document.getElementById('slide-ctr') as HTMLInputElement;
    const slideConv = document.getElementById('slide-conv') as HTMLInputElement;
    const slideCommission = document.getElementById('slide-commission') as HTMLInputElement;

    // Numbers
    const numTraffic = document.getElementById('num-traffic') as HTMLInputElement;
    const numCtr = document.getElementById('num-ctr') as HTMLInputElement;
    const numConv = document.getElementById('num-conv') as HTMLInputElement;
    const numCommission = document.getElementById('num-commission') as HTMLInputElement;

    // Outputs
    const outMonthly = document.getElementById('out-monthly');
    const outYearly = document.getElementById('out-yearly');
    const outClicks = document.getElementById('out-clicks');
    const outSales = document.getElementById('out-sales');

    // Funnel Visual elements
    const funnelTraffic = document.getElementById('funnel-traffic');
    const funnelClicks = document.getElementById('funnel-clicks');
    const funnelSales = document.getElementById('funnel-sales');
    const barClicks = document.getElementById('bar-clicks');
    const barSales = document.getElementById('bar-sales');

    if (
      !slideTraffic || !slideCtr || !slideConv || !slideCommission ||
      !numTraffic || !numCtr || !numConv || !numCommission ||
      !outMonthly || !outYearly || !outClicks || !outSales ||
      !funnelTraffic || !funnelClicks || !funnelSales || !barClicks || !barSales
    ) return;

    const formatCurrency = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(val);
    };

    const formatDecimal = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        maximumFractionDigits: 0
      }).format(val);
    };

    const calculate = (triggerSource: 'slider' | 'number') => {
      let traffic = 50000;
      let ctr = 2.0;
      let conv = 1.5;
      let commission = 50;

      if (triggerSource === 'slider') {
        traffic = parseFloat(slideTraffic.value) || 0;
        ctr = parseFloat(slideCtr.value) || 0;
        conv = parseFloat(slideConv.value) || 0;
        commission = parseFloat(slideCommission.value) || 0;

        // Synchronize numbers
        numTraffic.value = String(traffic);
        numCtr.value = ctr.toFixed(2);
        numConv.value = conv.toFixed(2);
        numCommission.value = commission.toFixed(2);
      } else {
        traffic = Math.max(0, parseFloat(numTraffic.value) || 0);
        ctr = Math.min(100, Math.max(0, parseFloat(numCtr.value) || 0));
        conv = Math.min(100, Math.max(0, parseFloat(numConv.value) || 0));
        commission = Math.max(0, parseFloat(numCommission.value) || 0);

        // Synchronize sliders
        slideTraffic.value = String(Math.min(parseFloat(slideTraffic.max), traffic));
        slideCtr.value = String(Math.min(parseFloat(slideCtr.max), ctr));
        slideConv.value = String(Math.min(parseFloat(slideConv.max), conv));
        slideCommission.value = String(Math.min(parseFloat(slideCommission.max), commission));
      }

      // Projections
      const clicks = traffic * (ctr / 100);
      const sales = clicks * (conv / 100);
      const monthlyEarnings = sales * commission;
      const yearlyEarnings = monthlyEarnings * 12;

      // Update Dashboard outputs
      outMonthly.textContent = formatCurrency(monthlyEarnings);
      outYearly.textContent = formatCurrency(yearlyEarnings);
      outClicks.textContent = formatDecimal(clicks);
      outSales.textContent = formatDecimal(sales);

      // Update Funnel metrics
      funnelTraffic.textContent = `${formatDecimal(traffic)} visitors`;
      funnelClicks.textContent = `${formatDecimal(clicks)} clicks (${ctr.toFixed(2)}% CTR)`;
      funnelSales.textContent = `${formatDecimal(sales)} sales (${conv.toFixed(2)}% CR)`;

      // Update Funnel widths
      const clickWidth = Math.max(1, Math.min(100, (clicks / traffic) * 100 * 20)); // scale for visibility
      const saleWidth = Math.max(1, Math.min(100, (sales / clicks) * 100 * 3)); // scale
      
      barClicks.style.width = `${ctr > 0 ? clickWidth : 0}%`;
      barSales.style.width = `${conv > 0 ? saleWidth : 0}%`;
    };

    // Slider Event Listeners
    [slideTraffic, slideCtr, slideConv, slideCommission].forEach(slider => {
      slider.addEventListener('input', () => calculate('slider'));
    });

    // Number Event Listeners
    [numTraffic, numCtr, numConv, numCommission].forEach(numInput => {
      numInput.addEventListener('input', () => calculate('number'));
      numInput.addEventListener('blur', () => {
        // Enforce validation boundaries on focus loss
        if (numTraffic.value === '' || parseFloat(numTraffic.value) < 1) numTraffic.value = '1';
        if (parseFloat(numCtr.value) < 0.01) numCtr.value = '0.01';
        if (parseFloat(numCtr.value) > 100) numCtr.value = '100';
        if (parseFloat(numConv.value) < 0.01) numConv.value = '0.01';
        if (parseFloat(numConv.value) > 100) numConv.value = '100';
        if (numCommission.value === '' || parseFloat(numCommission.value) < 0.1) numCommission.value = '0.1';
        calculate('number');
      });
    });

    // Run first calculation
    calculate('slider');
  };

  setupAffiliateCalculator();
  document.addEventListener('astro:after-swap', setupAffiliateCalculator);
</script>
