---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ToolCard from "../../components/ToolCard.astro";

// Real Interactive Tools
const realTools = [
  {
    id: "affiliate-calculator",
    name: "Affiliate Earnings Calculator",
    category: "calculators",
    categoryLabel: "Calculator",
    description: "Project your monthly and annual commission payouts based on visitor volume, CTR, conversion rates, and item prices.",
    pricing: "Free",
    rating: 4.8,
    link: "/tools/affiliate-earnings-calculator",
    color: "from-emerald-500/10 to-teal-500/10 border-teal-200/50",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-emerald-600">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
    </svg>`
  },
  {
    id: "roi-calculator",
    name: "Ad Spend ROI Calculator",
    category: "calculators",
    categoryLabel: "Calculator",
    description: "Calculate CPC, CTR, conversion rates, and total return on investment for your marketing campaigns instantly.",
    pricing: "Free",
    rating: 4.9,
    link: "/#calculators",
    color: "from-amber-500/10 to-orange-500/10 border-orange-200/50",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-orange-600">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
    </svg>`
  },
  {
    id: "youtube-calculator",
    name: "YouTube Earnings Calculator",
    category: "calculators",
    categoryLabel: "Calculator",
    description: "Model estimated AdSense earnings using daily views, average CPM metrics, and geographical demographics.",
    pricing: "Free",
    rating: 4.9,
    link: "/tools/youtube-earnings-calculator",
    color: "from-rose-500/10 to-red-500/10 border-red-200/50",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-rose-600">
      <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
    </svg>`
  }
];

// Planned calculators
const plannedTools = [
  {
    id: "profit-calculator",
    name: "Profit Margin Calculator",
    category: "calculators",
    categoryLabel: "Calculator",
    description: "Calculate cost of goods, retail markup, gross margin ratios, and net profit results for retail and e-commerce setups.",
    pricing: "Free",
    rating: 0,
    link: "#",
    color: "from-blue-500/10 to-teal-500/10 border-blue-200/50",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-blue-600">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" />
    </svg>`
  }
];

const totalRealCount = realTools.length;
const totalPlannedCount = plannedTools.length;
---

<Layout title="Free Interactive Calculators & Tools - Imperial Picks" description="Model your digital marketing campaign budgets, ROI parameters, profit margins, and affiliate conversion payouts with our clean, zero-dependency tools.">
  <Navbar />
  
  <main class="relative bg-slate-50 min-h-screen py-12">
    <!-- Background Patterns -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Breadcrumbs -->
      <nav class="flex text-xs font-semibold text-slate-500 gap-1.5 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-indigo-600">Home</a>
        <span>/</span>
        <span class="text-slate-800 font-bold">Calculators</span>
      </nav>

      <!-- Hero Section -->
      <div class="bg-white border border-slate-200/80 rounded-3xl p-6 sm:p-10 lg:p-12 shadow-xs mb-12">
        <div class="max-w-3xl">
          <span class="inline-flex items-center rounded-md bg-amber-50 px-2.5 py-1 text-xs font-bold text-amber-800 ring-1 ring-amber-600/15 mb-4 border border-amber-200/40">
            Interactive Tools
          </span>
          <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-4">
            Free Interactive Calculators
          </h1>
          <p class="text-base sm:text-lg text-slate-600 leading-relaxed">
            Run mock numbers and model your business metrics. Tweak budgets, click-through rates, payouts, and conversion splits to see projected profits, commissions, and revenue growth.
          </p>

          <!-- Dynamic Statistics Badge -->
          <div class="flex items-center gap-6 mt-8 border-t border-slate-100 pt-6">
            <div>
              <span class="text-xs font-semibold text-slate-400 block uppercase tracking-wider">Active Tools</span>
              <span class="text-2xl font-black text-slate-900 mt-1 block">{totalRealCount} Operational</span>
            </div>
            <div class="h-8 w-px bg-slate-200"></div>
            <div>
              <span class="text-xs font-semibold text-slate-400 block uppercase tracking-wider">In Development</span>
              <span class="text-2xl font-black text-slate-500 mt-1 block">{totalPlannedCount} Planned</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Controls Panel (Search & Filter) -->
      <div class="bg-white border border-slate-200/80 rounded-3xl p-6 shadow-xs mb-10">
        <div class="flex flex-col md:flex-row gap-4 justify-between items-center">
          
          <!-- Search box -->
          <div class="w-full md:max-w-md relative">
            <label for="search-input" class="sr-only">Search Tools</label>
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search calculators (e.g. ROI, Affiliate)..." 
              class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 pl-10 text-sm font-medium text-slate-900 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
            />
            <svg class="h-5 w-5 text-slate-400 absolute left-3 top-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>

          <!-- Type Filters -->
          <div class="flex flex-wrap gap-1.5 self-start md:self-auto" id="tool-filters">
            <button 
              data-filter="all" 
              class="filter-btn rounded-xl px-3.5 py-1.5 text-xs font-bold bg-indigo-600 text-white transition-colors"
            >
              All Tools
            </button>
            <button 
              data-filter="operational" 
              class="filter-btn rounded-xl px-3.5 py-1.5 text-xs font-bold bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/60 transition-colors"
            >
              Operational
            </button>
            <button 
              data-filter="planned" 
              class="filter-btn rounded-xl px-3.5 py-1.5 text-xs font-bold bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200/60 transition-colors"
            >
              Planned
            </button>
          </div>

        </div>
      </div>

      <!-- Content Sections -->
      <div class="space-y-16">
        
        <!-- Active Tools Grid -->
        <div>
          <h2 class="font-display text-xl sm:text-2xl font-bold text-slate-900 tracking-tight mb-6 flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span> Available Utilities
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="tools-grid">
            {realTools.map((tool) => (
              <div class="tool-wrapper" data-status="operational" data-name={tool.name.toLowerCase()} data-description={tool.description.toLowerCase()}>
                <ToolCard {...tool} />
              </div>
            ))}
            
            {plannedTools.map((tool) => (
              <div class="tool-wrapper" data-status="planned" data-name={tool.name.toLowerCase()} data-description={tool.description.toLowerCase()}>
                <ToolCard {...tool} comingSoon={true} />
              </div>
            ))}
          </div>

          <!-- Empty State -->
          <div id="empty-state" class="hidden bg-white border border-slate-200/80 rounded-3xl p-12 text-center max-w-md mx-auto">
            <div class="h-12 w-12 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center mx-auto mb-4 border border-slate-200/60">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-display text-base font-bold text-slate-900">No Calculators Found</h3>
            <p class="text-xs text-slate-500 mt-2">
              We couldn't find any tools matching your search criteria. Try modifying your terms.
            </p>
          </div>
        </div>

      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  const setupToolFilters = () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const filterButtons = document.querySelectorAll('.filter-btn');
    const tools = document.querySelectorAll('.tool-wrapper');
    const emptyState = document.getElementById('empty-state');
    const toolsGrid = document.getElementById('tools-grid');

    if (!tools.length) return;

    let activeFilter = 'all';
    let searchQuery = '';

    const filterTools = () => {
      let visibleCount = 0;

      tools.forEach(tool => {
        const name = tool.getAttribute('data-name') || '';
        const description = tool.getAttribute('data-description') || '';
        const status = tool.getAttribute('data-status') || '';

        const matchesSearch = name.includes(searchQuery) || description.includes(searchQuery);
        const matchesFilter = activeFilter === 'all' || status === activeFilter;

        if (matchesSearch && matchesFilter) {
          tool.classList.remove('hidden');
          visibleCount++;
        } else {
          tool.classList.add('hidden');
        }
      });

      // Toggle Empty State
      if (emptyState && toolsGrid) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
          toolsGrid.classList.add('hidden');
        } else {
          emptyState.classList.add('hidden');
          toolsGrid.classList.remove('hidden');
        }
      }
    };

    // Filter Buttons listeners
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filterVal = btn.getAttribute('data-filter') || 'all';

        // Toggle active design styles
        filterButtons.forEach(b => {
          b.classList.remove('bg-indigo-600', 'text-white');
          b.classList.add('bg-slate-50', 'text-slate-600', 'border-slate-200/60');
        });
        btn.classList.add('bg-indigo-600', 'text-white');
        btn.classList.remove('bg-slate-50', 'text-slate-600', 'border-slate-200/60');

        activeFilter = filterVal;
        filterTools();
      });
    });

    // Search input listener
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        searchQuery = searchInput.value.toLowerCase().trim();
        filterTools();
      });
    }
  };

  setupToolFilters();
  document.addEventListener('astro:after-swap', setupToolFilters);
</script>
