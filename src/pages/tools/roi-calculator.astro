---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

// FAQ Schema for SEO
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Return on Investment (ROI)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Return on Investment (ROI) is a financial metric used to evaluate the efficiency or profitability of an investment. It measures the amount of return on an investment relative to its initial cost, expressed as a percentage."
      }
    },
    {
      "@type": "Question",
      "name": "How is ROI calculated with operating costs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To calculate ROI including operating costs, use the formula: ROI = ((Revenue - Costs - Initial Investment) / Initial Investment) x 100. This ensures that ongoing costs are subtracted from the gross revenues before dividing by the investment cost."
      }
    },
    {
      "@type": "Question",
      "name": "What is a good ROI percentage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 'good' ROI depends heavily on the industry, asset class, and risk level. In general, an annual ROI of 7% to 10% is considered good for stock market index funds, while digital marketing campaigns (like SEO or PPC) often target an ROI of 400% to 500% (a 4:1 or 5:1 ratio of revenue to spend)."
      }
    },
    {
      "@type": "Question",
      "name": "Can ROI be negative?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If the total revenue generated is less than the sum of your initial investment and operating costs, the net profit is negative, resulting in a negative ROI. This indicates a financial loss on the investment."
      }
    },
    {
      "@type": "Question",
      "name": "How does ROI differ from Profit Margin?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Profit Margin measures how much net profit is retained from each dollar of revenue generated (Net Profit / Revenue). ROI measures how much return you generate relative to the cash you spent to start the project (Net Profit / Investment)."
      }
    },
    {
      "@type": "Question",
      "name": "Does this calculator support compounding returns over time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. This calculator is designed for simple, absolute ROI modeling of single campaigns or fixed-term projects. For compound interest projections over multiple years, you should use a dedicated compounding calculator."
      }
    },
    {
      "@type": "Question",
      "name": "What are the limitations of simple ROI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Simple ROI does not take into account the time value of money. An investment that yields a 50% ROI in one month is much more profitable than one that yields 50% ROI in five years, but the simple ROI formula ranks them identically. It also ignores cash flow timing and risk factors."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate ROI if my Initial Investment is zero?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mathematically, you cannot divide by zero, so ROI is undefined if the initial investment is $0. In business practice, if you have no upfront capital investment (e.g., organic social posts), you should treat your time cost as the investment, or measure profitability using gross profit margins instead of ROI."
      }
    },
    {
      "@type": "Question",
      "name": "What costs should I include in the calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You should include all costs directly associated with running the project or campaign. This includes ad spend, software subscriptions, transaction fees, agency hires, employee labor hours, and product manufacturing costs."
      }
    },
    {
      "@type": "Question",
      "name": "How does transaction volume impact ad campaign ROI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Higher transaction volumes can dilute ROI if acquisition costs (CAC) scale upward. However, if your sales conversion rates remain stable, higher volume can increase total net profit even if the ROI percentage slightly declines due to rising ad costs."
      }
    },
    {
      "@type": "Question",
      "name": "Is past campaign ROI a guarantee of future performance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Past ROI is never a guarantee of future campaign results. Market competition, changes in advertising algorithms, seasonal demand variations, and product pricing adjustments can all significantly impact future return rates."
      }
    }
  ]
};
---

<Layout title="Free ROI Calculator (Return on Investment) - Imperial Picks" description="Calculate your Return on Investment (ROI) instantly. Adjust initial investment, revenue generated, and operating costs to project net profits and ROI percentages in real time.">
  
  <!-- FAQ Schema Injection -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <Navbar />
  
  <main class="relative bg-slate-50 min-h-screen py-12">
    <!-- Background Patterns -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="flex text-xs font-semibold text-slate-500 gap-1.5 mb-6 relative z-10" aria-label="Breadcrumb">
        <a href="/" class="hover:text-indigo-600">Home</a>
        <span>/</span>
        <a href="/tools" class="hover:text-indigo-600">Calculators</a>
        <span>/</span>
        <span class="text-slate-800 truncate">ROI Calculator</span>
      </nav>

      <!-- Page Header -->
      <div class="text-center max-w-3xl mx-auto mb-12 relative z-10">
        <div class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-800 ring-1 ring-indigo-600/15 mb-4">
          Financial Analytics
        </div>
        <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Return on Investment (ROI) Calculator
        </h1>
        <p class="mt-3 text-base text-slate-600">
          Determine the profitability and capital efficiency of your marketing campaigns, software stack migration, or business investments. Adjust sliders in real time to model returns.
        </p>
      </div>

      <!-- Main Widget Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 relative z-10 max-w-5xl mx-auto mb-16">
        
        <!-- Left Side: Inputs & Sliders -->
        <div class="lg:col-span-7 bg-white rounded-3xl border border-slate-200 p-6 sm:p-8 shadow-sm space-y-6">
          <h2 class="font-display text-lg font-bold text-slate-900 border-b border-slate-100 pb-3">
            Investment Parameters
          </h2>

          <!-- Parameter 1: Initial Investment -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-investment" class="text-sm font-semibold text-slate-700">Initial Investment ($)</label>
              <div class="flex items-center gap-1.5">
                <span class="text-xs text-slate-400 font-bold">$</span>
                <input 
                  type="number" 
                  id="num-investment" 
                  min="0" 
                  max="10000000" 
                  value="10000"
