            <input 
              type="range" 
              id="slide-costs" 
              min="0" 
              max="100000" 
              step="500" 
              value="5000" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

        </div>

        <!-- Right Side: Projections Dashboard -->
        <div class="lg:col-span-5 flex flex-col justify-between rounded-3xl bg-slate-900 text-white border border-slate-800 p-6 sm:p-8 shadow-lg">
          
          <div>
            <h2 class="font-display text-lg font-bold border-b border-white/10 pb-3 mb-6">
              Calculation Dashboard
            </h2>

            <!-- Metric Cards -->
            <div class="space-y-4">
              
              <!-- ROI Status Banner -->
              <div id="status-card" class="p-4 rounded-2xl bg-emerald-500/10 border border-emerald-500/30 text-center transition-colors duration-300">
