                />
              </div>
            </div>
            <input 
              type="range" 
              id="slide-investment" 
              min="0" 
              max="100000" 
              step="500" 
              value="10000" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Parameter 2: Revenue Generated -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-revenue" class="text-sm font-semibold text-slate-700">Revenue Generated ($)</label>
              <div class="flex items-center gap-1.5">
                <span class="text-xs text-slate-400 font-bold">$</span>
                <input 
                  type="number" 
                  id="num-revenue" 
                  min="0" 
                  max="10000000" 
                  value="25000"
                  class="w-28 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-right text-sm font-bold text-indigo-600 focus:bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                />
              </div>
            </div>
            <input 
              type="range" 
              id="slide-revenue" 
              min="0" 
              max="200000" 
              step="1000" 
              value="25000" 
              class="w-full h-2 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600"
            />
          </div>

          <!-- Parameter 3: Costs -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <label for="num-costs" class="text-sm font-semibold text-slate-700">Operating Costs ($)</label>
