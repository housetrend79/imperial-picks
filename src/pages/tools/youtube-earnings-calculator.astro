<script>
  const setupYoutubeCalculator = () => {
    // Sliders
    const slideViews = document.getElementById('slide-views') as HTMLInputElement;
    const slideCpm = document.getElementById('slide-cpm') as HTMLInputElement;
    const slideRpm = document.getElementById('slide-rpm') as HTMLInputElement;
    const slideMonetization = document.getElementById('slide-monetization') as HTMLInputElement;

    // Number Inputs
    const numViews = document.getElementById('num-views') as HTMLInputElement;
    const numCpm = document.getElementById('num-cpm') as HTMLInputElement;
    const numRpm = document.getElementById('num-rpm') as HTMLInputElement;
    const numMonetization = document.getElementById('num-monetization') as HTMLInputElement;

    // Outputs
    const outMonthly = document.getElementById('out-monthly');
    const outYearly = document.getElementById('out-yearly');
    const rangeLow = document.getElementById('range-low');
    const rangeAvg = document.getElementById('range-avg');
    const rangeHigh = document.getElementById('range-high');
    const cpmRpmWarning = document.getElementById('cpm-rpm-warning');

    if (
      !slideViews || !slideCpm || !slideRpm || !slideMonetization ||
      !numViews || !numCpm || !numRpm || !numMonetization ||
      !outMonthly || !outYearly || !rangeLow || !rangeAvg || !rangeHigh || !cpmRpmWarning
    ) return;

    const formatCurrency = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        maximumFractionDigits: 0
      }).format(val);
    };

    const formatDecimal = (val: number) => {
      return new Intl.NumberFormat('en-US', {
        maximumFractionDigits: 0
      }).format(val);
    };

    const calculate = (triggerSource: 'slider' | 'number') => {
      let views = 100000;
      let cpm = 6.00;
      let rpm = 3.00;
      let monetization = 60;

      if (triggerSource === 'slider') {
        views = parseFloat(slideViews.value) || 0;
        cpm = parseFloat(slideCpm.value) || 0;
        rpm = parseFloat(slideRpm.value) || 0;
        monetization = parseFloat(slideMonetization.value) || 0;

        // Synchronize numbers
        numViews.value = String(views);
        numCpm.value = cpm.toFixed(2);
        numRpm.value = rpm.toFixed(2);
        numMonetization.value = String(monetization);
      } else {
        views = Math.max(0, parseFloat(numViews.value) || 0);
        cpm = Math.max(0, parseFloat(numCpm.value) || 0);
        rpm = Math.max(0, parseFloat(numRpm.value) || 0);
        monetization = Math.min(100, Math.max(0, parseFloat(numMonetization.value) || 0));

        // Synchronize sliders
        slideViews.value = String(Math.min(parseFloat(slideViews.max), views));
        slideCpm.value = String(Math.min(parseFloat(slideCpm.max), cpm));
        slideRpm.value = String(Math.min(parseFloat(slideRpm.max), rpm));
        slideMonetization.value = String(Math.min(parseFloat(slideMonetization.max), monetization));
      }

      // Calculations
      const monthlyRevenue = (views / 1000) * rpm;
      const yearlyRevenue = monthlyRevenue * 12;

      // Low: AdSense Ad Share baseline: Views * MonetizationRate * CPM * 55% creator share
      const lowEstimate = (views / 1000) * (monetization / 100) * cpm * 0.55;
      const avgEstimate = monthlyRevenue;
      // High: Optimized with memberships and premium sponsorship potential (1.5x)
      const highEstimate = monthlyRevenue * 1.5;

      // Update UI outputs
      outMonthly.textContent = formatCurrency(monthlyRevenue);
      outYearly.textContent = formatCurrency(yearlyRevenue);
      rangeLow.textContent = formatCurrency(lowEstimate);
      rangeAvg.textContent = formatCurrency(avgEstimate);
      rangeHigh.textContent = formatCurrency(highEstimate);

      // Warning when RPM is greater than CPM
      if (rpm > cpm) {
        cpmRpmWarning.classList.remove('hidden');
      } else {
        cpmRpmWarning.classList.add('hidden');
      }
    };

    // Slider Event Listeners
    [slideViews, slideCpm, slideRpm, slideMonetization].forEach(slider => {
      slider.addEventListener('input', () => calculate('slider'));
    });

    // Number Inputs Event Listeners
    [numViews, numCpm, numRpm, numMonetization].forEach(numInput => {
      numInput.addEventListener('input', () => calculate('number'));
      numInput.addEventListener('blur', () => {
        // Enforce validation boundaries on focus loss
        if (numViews.value === '' || parseFloat(numViews.value) < 100) numViews.value = '100';
        if (parseFloat(numCpm.value) < 0.1) numCpm.value = '0.1';
        if (parseFloat(numRpm.value) < 0.05) numRpm.value = '0.05';
        if (parseFloat(numMonetization.value) < 5) numMonetization.value = '5';
        if (parseFloat(numMonetization.value) > 100) numMonetization.value = '100';
        calculate('number');
      });
    });

    // Run first calculation
    calculate('slider');
  };

  setupYoutubeCalculator();
  document.addEventListener('astro:after-swap', setupYoutubeCalculator);
</script>
