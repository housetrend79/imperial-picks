                class="inline-flex items-center justify-center w-full rounded-xl bg-white text-indigo-950 py-2.5 mt-4 text-xs font-bold shadow-xs hover:bg-slate-100 transition-colors"
              >
                Submit Now
              </a>
            </div>

          </div>
        </aside>

      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Simple active state observer for the Table of Contents sidebar
  const setupTOC = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const id = entry.target.getAttribute('id');
        const tocLink = document.querySelector(`.toc-link[href="#${id}"]`);
        
        if (!tocLink) return;

        if (entry.isIntersecting) {
          tocLink.classList.add('text-indigo-600');
          tocLink.classList.remove('text-slate-600', 'text-slate-500');
        } else {
          tocLink.classList.remove('text-indigo-600');
          if (tocLink.classList.contains('text-xs')) {
            tocLink.classList.add('text-slate-500');
          } else {
            tocLink.classList.add('text-slate-600');
          }
        }
      });
    }, {
      rootMargin: '-100px 0px -60% 0px'
    });

    const targets = document.querySelectorAll('section[id], div[id^="tool-"]');
    targets.forEach(target => observer.observe(target));
  };

  setupTOC();
  document.addEventListener('astro:after-swap', setupTOC);
</script>
