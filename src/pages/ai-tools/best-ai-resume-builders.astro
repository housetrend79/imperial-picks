---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

// Schema Markup for SEO
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "Best AI Resume Builders in 2026: Unbiased Editorial Review",
  "description": "Compare the best AI resume builders in 2026. Honest, non-sponsored reviews of Teal, Kickresume, Resume.io, Enhancv, Rezi, and Canva Resume Builder with pros, cons, pricing, and ATS compatibility analyses.",
  "datePublished": "2026-06-11T12:15:00Z",
  "dateModified": "2026-06-11T12:15:00Z",
  "author": {
    "@type": "Organization",
    "name": "Imperial Picks Editorial Team",
    "url": "https://imperialpicks.in/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Imperial Picks",
    "logo": {
      "@type": "ImageObject",
      "url": "https://imperialpicks.in/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://imperialpicks.in/ai-tools/best-ai-resume-builders"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an ATS, and why is it important for AI resume building?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An Applicant Tracking System (ATS) is software recruiters use to collect, sort, and search job applications. Many visually complex resume designs (such as multi-column layouts, tables, and graphic elements) confuse ATS parsers. AI resume builders optimize layout structures and keyword densities to ensure the resume parses cleanly in ATS systems."
      }
    },
    {
      "@type": "Question",
      "name": "Can recruiters tell if a resume was written by AI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, if the resume is filled with generic AI clichés like 'highly motivated professional with a proven track record of synergy.' Recruiter tools do not typically use automatic AI detectors to filter resumes, but human readers can easily spot copy-pasted summaries. The key is to use AI to draft raw statements and then manually edit them to add specific personal metrics."
      }
    },
    {
      "@type": "Question",
      "name": "Which AI resume builder is best for matching job descriptions?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Teal and Rezi are the leaders in job matching. Teal features a job tracker browser extension that extracts keywords from a live listing and scores your resume's relevance in real time. Rezi offers a highly structured keyword analyzer that suggests exact phrases to include in each section."
      }
    },
    {
      "@type": "Question",
      "name": "Is Canva's AI Resume Builder compatible with ATS systems?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Canva is excellent for creative industries (like design, marketing, and media) where a human reviews the resume first. However, many of Canva's default graphic templates are not ATS-friendly. If you are applying to large enterprises, you should stick to simple single-column layouts like those generated by Rezi or Teal."
      }
    },
    {
      "@type": "Question",
      "name": "Are these platforms secure for storing personal contact information?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Established builders like Teal, Kickresume, and Resume.io use HTTPS encryption and comply with general privacy frameworks (like GDPR). However, you should review each platform's settings to ensure your resume is kept private and not listed publicly on search engines unless you explicitly choose to share it."
      }
    },
    {
      "@type": "Question",
      "name": "How does Teal compare to Rezi for career tracking?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Teal operates as a full career growth hub, featuring job trackers, contact databases, email templates, and resume analyzers. Rezi is a highly focused resume and cover letter builder designed to optimize single documents for maximum ATS compatibility."
      }
    },
    {
      "@type": "Question",
      "name": "Can I import my existing LinkedIn profile into these builders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Most leading builders (including Kickresume, Teal, and Resume.io) allow you to upload a LinkedIn PDF export or a raw JSON/DOCX file to automatically populate your work history, saving hours of manual data entry."
      }
    },
    {
      "@type": "Question",
      "name": "Do AI resume builders generate cover letters as well?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, platforms like Kickresume, Rezi, and Resume.io include integrated cover letter generators that draft letters customized to specific job descriptions based on the experience listed on your resume."
      }
    },
    {
      "@type": "Question",
      "name": "What are the common pricing models for AI resume software in 2026?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most platforms offer a free tier with basic template access and limited AI credits. Premium tiers (ranging from $8 to $29/month) provide unlimited AI generation, advanced ATS analysis, custom cover letters, and unlimited document downloads."
      }
    },
    {
      "@type": "Question",
      "name": "What is the single most common mistake when using AI to build a resume?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Failing to check AI-generated achievements. AI can write excellent action verbs, but it does not know your actual results. You must replace generic metrics with your real statistics (e.g., changing 'improved team efficiency' to 'reduced server response times by 32%')."
      }
    },
    {
      "@type": "Question",
      "name": "Can I download my resume as a Microsoft Word file?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. While PDF is the industry standard for emailing resumes, Rezi and Resume.io allow DOCX exports, which are useful if you need to submit raw files to specific corporate portals."
      }
    }
  ]
};
---

<Layout title="Best AI Resume Builders in 2026: Unbiased Editorial Review - Imperial Picks" description="Compare the top AI resume builders in 2026. Read non-sponsored, detailed reviews, pricing, pros, cons, and guide for Teal, Kickresume, Resume.io, Enhancv, Rezi, and Canva.">
  
  <!-- Inject JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <Navbar />
  
  <main class="relative bg-slate-50 min-h-screen py-12">
    <!-- Background Patterns -->
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs -->
      <nav class="flex text-xs font-semibold text-slate-500 gap-1.5 mb-6 relative z-10" aria-label="Breadcrumb">
        <a href="/" class="hover:text-indigo-600">Home</a>
        <span>/</span>
        <a href="/ai-tools" class="hover:text-indigo-600">AI Tools</a>
        <span>/</span>
        <span class="text-slate-800 truncate">Best AI Resume Builders</span>
      </nav>

      <!-- Layout Grid: Left Content (Prose), Right Sticky Table of Contents -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10">
        
        <!-- Main Article Body (Prose) -->
        <article class="lg:col-span-8 bg-white border border-slate-200/80 rounded-3xl p-6 sm:p-10 lg:p-12 shadow-xs max-w-none">
          
          <!-- Article Header -->
          <header class="border-b border-slate-100 pb-8 mb-8">
            <span class="inline-flex items-center rounded-md bg-emerald-50 px-2.5 py-1 text-xs font-bold text-emerald-800 mb-4 border border-emerald-200/40">
              Career & Employment
            </span>
            <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-black text-slate-900 tracking-tight leading-[1.15] mb-6">
              Best AI Resume Builders in 2026: Unbiased Editorial Review
            </h1>
            
            <!-- Author Card -->
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-indigo-600 text-indigo-50 flex items-center justify-center font-display text-sm font-bold shadow-sm">
                IP
              </div>
              <div class="text-xs">
                <p class="font-bold text-slate-800">Imperial Picks Editorial Team</p>
                <p class="text-slate-400 font-medium mt-0.5">Published on June 11, 2026 • 20 min read</p>
              </div>
            </div>
          </header>

          <!-- Introduction Section -->
          <section id="introduction" class="prose max-w-[72ch] text-slate-600 text-sm leading-relaxed space-y-6">
            <h2 class="sr-only">Introduction</h2>
            <p class="text-base sm:text-lg font-medium">
              The recruitment process in 2026 is driven by automated screening systems. Before a human hiring manager ever looks at your application, it must pass through an Applicant Tracking System (ATS). These platforms parse your document, extract your work history, and score your skills against the job description.
            </p>
            <p>
              Historically, job seekers spent hours custom-formatting documents in Microsoft Word, only to have the ATS parse them incorrectly due to a hidden table or two-column layout. Today, artificial intelligence has changed this workflow. Modern resume tools do not just write bullet points; they design ATS-compatible layouts, analyze job descriptions for critical keywords, and score your resume's relevance in real time.
            </p>
            <p>
              However, the market is flooded with subpar tools. Many are simple wrappers around basic language models that output generic, buzzword-heavy copy like "results-driven team player." Furthermore, some resume platforms default to graphic layouts that look great in a browser but fail ATS parsing, leaving your application lost in the database.
            </p>
            <p>
              To help you stand out, the Imperial Picks Editorial Team has conducted an independent audit of the leading systems. In this guide, we analyze the six best AI resume builders in 2026, evaluating their ATS compatibility, AI accuracy, pros, cons, and pricing models.
            </p>

            <!-- Callout: Trust & Data Integrity -->
            <div class="border-l-4 border-indigo-500 bg-indigo-50/50 p-5 rounded-r-2xl my-8">
              <div class="flex gap-2.5">
                <span class="text-lg">🔒</span>
                <div>
                  <h4 class="font-bold text-indigo-900 text-sm">Our Editorial Promise</h4>
                  <p class="text-xs text-indigo-800 leading-relaxed mt-1">
                    At Imperial Picks, we test software ourselves. This review contains no sponsored rankings or affiliate links. We evaluate tools based on template code quality, ATS parsing rates, browser extension features, and actual value for money.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <!-- Comparison Table Section -->
          <section id="comparison-table" class="mt-12 scroll-mt-20">
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight mb-6 pb-2 border-b border-slate-100">
              2. Quick Comparison: AI Resume Builders
            </h2>
            <p class="text-sm text-slate-600 leading-relaxed mb-6">
              The table below summarizes the key trade-offs in template types, free plan availability, starting prices, and primary use cases of the top resume engines.
            </p>
            
            <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-slate-50/50 p-1 mb-8">
              <table class="w-full text-left text-xs border-collapse bg-white rounded-xl overflow-hidden">
                <thead>
                  <tr class="bg-slate-900 text-white font-display text-[10px] uppercase tracking-wider">
                    <th class="py-4 px-4 font-semibold">Builder</th>
                    <th class="py-4 px-4 font-semibold">Best For</th>
                    <th class="py-4 px-4 font-semibold">Free Plan</th>
                    <th class="py-4 px-4 font-semibold">Starting Price</th>
                    <th class="py-4 px-4 font-semibold">Primary Feature</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-700">
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="py-4 px-4 font-bold text-slate-900">Teal</td>
                    <td class="py-4 px-4">Job tracking & real-time description matching</td>
                    <td class="py-4 px-4">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-800 border border-emerald-200/50">Yes (Basic matching)</span>
                    </td>
                    <td class="py-4 px-4 font-semibold text-slate-900">$9/week (or $29/mo)</td>
                    <td class="py-4 px-4">Job tracker chrome extension</td>
                  </tr>
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="py-4 px-4 font-bold text-slate-900">Kickresume</td>
                    <td class="py-4 px-4">Polished designs, websites, and cover letters</td>
                    <td class="py-4 px-4">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-800 border border-emerald-200/50">Yes (Basic templates)</span>
                    </td>
                    <td class="py-4 px-4 font-semibold text-slate-900">$9/month (billed annually)</td>
                    <td class="py-4 px-4">AI-driven resume-to-webpage converter</td>
                  </tr>
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="py-4 px-4 font-bold text-slate-900">Resume.io</td>
                    <td class="py-4 px-4">Fast template selection & executive formats</td>
                    <td class="py-4 px-4">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-800 border border-emerald-200/50">Yes (TXT file export)</span>
                    </td>
                    <td class="py-4 px-4 font-semibold text-slate-900">$2.95 (7-day trial)</td>
                    <td class="py-4 px-4">One-click template swapping</td>
                  </tr>
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="py-4 px-4 font-bold text-slate-900">Enhancv</td>
                    <td class="py-4 px-4">Visual graphics & modern styling accents</td>
                    <td class="py-4 px-4">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-800 border border-emerald-200/50">Yes (Basic editor)</span>
                    </td>
                    <td class="py-4 px-4 font-semibold text-slate-900">$10.99/month (billed annually)</td>
                    <td class="py-4 px-4">Section dragging editor</td>
                  </tr>
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="py-4 px-4 font-bold text-slate-900">Rezi</td>
                    <td class="py-4 px-4">Guaranteed ATS parsing & quantitative auditing</td>
                    <td class="py-4 px-4">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-800 border border-emerald-200/50">Yes (1 document)</span>
                    </td>
                    <td class="py-4 px-4 font-semibold text-slate-900">$19/month (or $129 lifetime)</td>
                    <td class="py-4 px-4">ATS compliance checker dashboard</td>
                  </tr>
                  <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="py-4 px-4 font-bold text-slate-900">Canva Resume Builder</td>
                    <td class="py-4 px-4">Creative portfolios & manual design customization</td>
                    <td class="py-4 px-4">
                      <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-0.5 text-[10px] font-semibold text-emerald-800 border border-emerald-200/50">Yes (Free templates)</span>
                    </td>
                    <td class="py-4 px-4 font-semibold text-slate-900">Free (Premium elements via Pro)</td>
                    <td class="py-4 px-4">Full drag-and-drop design workspace</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- Detailed Reviews Section -->
          <section id="detailed-reviews" class="mt-16 space-y-20">
            <h2 class="font-display text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight pb-2 border-b border-slate-100">
              3. Detailed Reviews: The Top 6 AI Resume Builders
            </h2>

            <!-- Review: Teal -->
            <div id="tool-teal" class="scroll-mt-20 space-y-4">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal-50 text-teal-600 border border-teal-100 font-bold font-display">01</span>
                <h3 class="font-display text-2xl font-extrabold text-slate-900">Teal: The Career Hub and Tracker</h3>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                Teal is far more than a simple document generator. It operates as a unified career growth database that integrates job search tracking, contact management, application follow-up logs, and resume customization into a single browser dashboard.
              </p>
              <p class="text-slate-600 text-sm leading-relaxed">
                The core strength of Teal is its Chrome browser extension. When you view a job listing on LinkedIn, Indeed, or Glassdoor, the extension extracts the role details, catalogs the listing in your Teal job board, and parses the key skills required. You can then build multiple versions of your resume, with Teal scoring your document's keyword density against the saved listing.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-6 text-xs">
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-5">
                  <h4 class="font-bold text-emerald-900 mb-2">Key Features</h4>
                  <ul class="list-disc pl-4 space-y-1 text-slate-600">
                    <li>Integrated Job Tracker extension that saves listings from any job board.</li>
                    <li>Real-time keyword analysis and description scoring.</li>
                    <li>Supports building multiple versions of your resume.</li>
                    <li>Built-in dashboard for contact and communication tracking.</li>
                  </ul>
                </div>
                <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-5">
                  <h4 class="font-bold text-slate-900 mb-2">Pros & Cons</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li><strong class="text-emerald-600">✓</strong> Keeps your job search organized across multiple platforms.</li>
                    <li><strong class="text-emerald-600">✓</strong> Clean, ATS-compliant template layouts.</li>
                    <li><strong class="text-rose-600">✗</strong> Interface can feel complex for users who only want a quick edit.</li>
                    <li><strong class="text-rose-600">✗</strong> AI content suggestions require a premium subscription.</li>
                  </ul>
                </div>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                <strong>Pricing:</strong> Free basic version available. Teal+ subscriptions cost $9/week (ideal for short job searches) or $29/month, providing unlimited AI generation and deeper keyword analytics.
              </p>
              <p class="text-slate-650 text-xs italic bg-slate-50 p-3.5 rounded-xl border border-slate-200/60">
                <strong>Best Use Case:</strong> Job seekers managing active applications across multiple platforms who want to match resumes to specific listings.
              </p>
            </div>

            <!-- Review: Kickresume -->
            <div id="tool-kickresume" class="scroll-mt-20 space-y-4">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-orange-50 text-orange-600 border border-orange-100 font-bold font-display">02</span>
                <h3 class="font-display text-2xl font-extrabold text-slate-900">Kickresume: The Creative Portfolio Partner</h3>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                For candidates who want a modern design that stands out visually, Kickresume is a leading choice. It utilizes OpenAI's models to draft experience descriptions, summary blurbs, and cover letters, pairing them with visually striking templates.
              </p>
              <p class="text-slate-600 text-sm leading-relaxed">
                The standout feature of Kickresume is its "Resume to Website" converter, which transforms your document into a responsive personal website in seconds. While it offers graphics, icons, and color choices, it also includes a section indicating which templates are optimized for ATS compatibility, helping you balance visual appeal with technical standards.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-6 text-xs">
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-5">
                  <h4 class="font-bold text-emerald-900 mb-2">Key Features</h4>
                  <ul class="list-disc pl-4 space-y-1 text-slate-600">
                    <li>One-click converter from resume to personal website.</li>
                    <li>AI cover letter and resignation letter generator.</li>
                    <li>Includes real resume examples from successful hires at Google and Apple.</li>
                    <li>Visually striking, custom-designed graphic templates.</li>
                  </ul>
                </div>
                <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-5">
                  <h4 class="font-bold text-slate-900 mb-2">Pros & Cons</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li><strong class="text-emerald-600">✓</strong> Outstanding designs for creative fields like marketing and design.</li>
                    <li><strong class="text-emerald-600">✓</strong> The website converter is a great value-add.</li>
                    <li><strong class="text-rose-600">✗</strong> Some template styles are not suitable for conservative, ATS-heavy roles.</li>
                    <li><strong class="text-rose-600">✗</strong> Free tier is limited to basic formatting options.</li>
                  </ul>
                </div>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                <strong>Pricing:</strong> Free basic tier with limited templates. Premium plans start at $9/month (billed annually) or $19/month (billed monthly).
              </p>
              <p class="text-slate-650 text-xs italic bg-slate-50 p-3.5 rounded-xl border border-slate-200/60">
                <strong>Best Use Case:</strong> Designers, marketers, and freelancers who need a visual resume and a personal portfolio website.
              </p>
            </div>

            <!-- Review: Resume.io -->
            <div id="tool-resumeio" class="scroll-mt-20 space-y-4">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-50 text-blue-600 border border-blue-100 font-bold font-display">03</span>
                <h3 class="font-display text-2xl font-extrabold text-slate-900">Resume.io: The Fast-Drafting Platform</h3>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                If you need to create a clean, professional resume quickly, Resume.io is designed for maximum speed. It features a straightforward, section-by-section builder that guides you through entering your information, with AI suggestions to fill in the details.
              </p>
              <p class="text-slate-600 text-sm leading-relaxed">
                Resume.io's AI engine offers pre-written phrases tailored to specific job titles, making it easy to describe your work history. It also supports one-click template swapping, allowing you to change your document's layout and font choices instantly without losing your formatting.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-6 text-xs">
                <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-5">
                  <h4 class="font-bold text-emerald-900 mb-2">Key Features</h4>
                  <ul class="list-disc pl-4 space-y-1 text-slate-600">
                    <li>One-click layout swapping.</li>
                    <li>AI suggestions for role-specific tasks and skills.</li>
                    <li>Integrated job search dashboard.</li>
                    <li>Automatic PDF and DOCX downloads.</li>
                  </ul>
                </div>
                <div class="bg-slate-50 border border-slate-200/60 rounded-2xl p-5">
                  <h4 class="font-bold text-slate-900 mb-2">Pros & Cons</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li><strong class="text-emerald-600">✓</strong> Fast and easy to use.</li>
                    <li><strong class="text-emerald-600">✓</strong> Clean templates suitable for all industries.</li>
                    <li><strong class="text-rose-600">✗</strong> Free version is limited to TXT exports.</li>
                    <li><strong class="text-rose-600">✗</strong> Requires a trial subscription to download PDFs.</li>
                  </ul>
                </div>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                <strong>Pricing:</strong> Free basic plan allows TXT downloads. A 7-day trial with full PDF exports costs $2.95, auto-renewing to $24.95/month if not cancelled.
              </p>
              <p class="text-slate-650 text-xs italic bg-slate-50 p-3.5 rounded-xl border border-slate-200/60">
                <strong>Best Use Case:</strong> Candidates who want to quickly build a classic, single-column resume.
              </p>
            </div>

            <!-- Review: Enhancv -->
            <div id="tool-enhancv" class="scroll-mt-20 space-y-4">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-purple-50 text-purple-600 border border-purple-100 font-bold font-display">04</span>
                <h3 class="font-display text-2xl font-extrabold text-slate-900">Enhancv: The Drag-and-Drop Editor</h3>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">
                Enhancv focus on visual structure, featuring an editor that allows you to drag and drop sections to customize your layout.
              </p>
              <p class="text-slate-600 text-sm leading-relaxed">
